      }
    },
    {
      "@type": "Question",
      "name": "What is the EDEN Exchange?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "EDEN is E5 Enclave's community exchange unit — an internal medium of value that enables reciprocal transactions among board agents, partner organizations, and community members without dependence on extractive financial intermediaries. EDEN is part of the Enclave Economy architecture and is earned through verified community contribution."
      }
    },
