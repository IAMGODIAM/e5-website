---
layout: null
pagination:
  data: gospel_papers
  size: 1
  alias: paper
permalink: /gospel/{{ paper.url_slug }}/
eleventyExcludeFromCollections: false
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>{% if paper.number == 0 %}Foreword{% else %}Paper {{ paper.number }} — {{ paper.title }}{% endif %} · Gospel of Love · E5 Enclave</title>
<meta name="description" content="{{ paper.overview | truncate(160) }}"/>
<link rel="canonical" href="https://gospel.e5enclave.com/{{ paper.url_slug }}/"/>
<meta property="og:title" content="{% if paper.number == 0 %}Foreword{% else %}Paper {{ paper.number }}{% endif %} — {{ paper.title }} · The Urantia Book"/>
<meta property="og:description" content="{{ paper.overview | truncate(200) }}"/>
<meta property="og:url" content="https://gospel.e5enclave.com/{{ paper.url_slug }}/"/>
<meta property="og:image" content="https://e5enclave.com/images/gospel-og.jpg"/>
<meta name="twitter:card" content="summary_large_image"/>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "{% if paper.number == 0 %}Foreword{% else %}Paper {{ paper.number }} — {{ paper.title }}{% endif %}",
  "description": {{ paper.overview | dump }},
  "url": "https://gospel.e5enclave.com/{{ paper.url_slug }}/",
  "isPartOf": {
    "@type": "Book",
    "name": "The Urantia Book",
    "url": "https://gospel.e5enclave.com/"
  },
  "publisher": {
    "@type": "Organization",
    "name": "E5 Enclave Incorporated",
    "url": "https://e5enclave.com"
  }
}
</script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --void:#030308;--deep:#08080f;--surface:#0f0f1a;
  --gold:#c8a254;--gold-dim:#8a6e3a;
  --cream:#f0ece0;--cream-dim:#a09880;
  --part-color:{{ paper.part.color }};
  --white:#f8f6f0;
  --glass:rgba(255,255,255,0.04);
  --glass-border:rgba(255,255,255,0.08);
}
html{scroll-behavior:smooth}
body{font-family:Georgia,'Times New Roman',serif;background:var(--void);color:var(--cream);line-height:1.8;overflow-x:hidden}

/* ── STARFIELD ── */
.starfield{position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden}
.star{position:absolute;border-radius:50%;background:var(--white)}
@keyframes starDrift{from{transform:translateY(0) rotate(0deg);opacity:.3}to{transform:translateY(-120vh) rotate(360deg);opacity:0}}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;justify-content:space-between;align-items:center;padding:14px 40px;backdrop-filter:blur(20px);background:rgba(3,3,8,.85);border-bottom:1px solid var(--glass-border);font-family:'Helvetica Neue',Arial,sans-serif;font-size:11px;text-transform:uppercase;letter-spacing:2px}
nav a{color:var(--cream-dim);text-decoration:none;transition:color .2s}
nav a:hover{color:var(--gold)}
.nav-brand{color:var(--gold);font-size:12px;letter-spacing:3px}
.nav-links{display:flex;gap:24px;align-items:center}
.nav-part-badge{color:var(--part-color);font-size:10px;letter-spacing:1px;opacity:.8}

/* ── HERO ── */
.hero{position:relative;z-index:1;min-height:45vh;display:flex;flex-direction:column;justify-content:flex-end;align-items:flex-start;padding:120px 80px 60px;border-bottom:1px solid var(--glass-border)}
.hero::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(3,3,8,.9) 0%,rgba(15,15,26,.7) 100%);z-index:-1}
.paper-part{font-family:'Helvetica Neue',Arial,sans-serif;font-size:11px;text-transform:uppercase;letter-spacing:3px;color:var(--part-color);margin-bottom:16px;opacity:.9}
.paper-number{font-family:'Helvetica Neue',Arial,sans-serif;font-size:13px;text-transform:uppercase;letter-spacing:4px;color:var(--cream-dim);margin-bottom:8px}
.paper-title{font-size:clamp(2rem,5vw,3.5rem);font-weight:400;color:var(--white);line-height:1.2;margin-bottom:24px;max-width:800px}
.paper-overview{font-size:1.1rem;color:var(--cream-dim);max-width:680px;line-height:1.8}

/* ── SECTIONS ── */
.content-wrap{position:relative;z-index:1;max-width:900px;margin:0 auto;padding:80px 40px}
.section-block{margin-bottom:80px}
.section-eyebrow{font-family:'Helvetica Neue',Arial,sans-serif;font-size:10px;text-transform:uppercase;letter-spacing:4px;color:var(--part-color);margin-bottom:20px}
.section-title{font-size:1.6rem;color:var(--gold);margin-bottom:28px;font-weight:400}
.sections-list{list-style:none;display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:12px}
.sections-list li{padding:14px 18px;background:var(--glass);border:1px solid var(--glass-border);border-left:3px solid var(--part-color);font-size:.9rem;color:var(--cream-dim);line-height:1.5;transition:border-color .2s,color .2s}
.sections-list li:hover{border-left-color:var(--gold);color:var(--cream)}

/* ── CORE TEACHING ── */
.core-block{background:var(--glass);border:1px solid var(--glass-border);border-left:4px solid var(--gold);border-radius:4px;padding:40px 48px;position:relative;overflow:hidden}
.core-block::before{content:'❝';position:absolute;top:-10px;left:20px;font-size:6rem;color:var(--gold);opacity:.07;font-family:Georgia,serif;line-height:1}
.core-text{font-size:1.15rem;line-height:2;color:var(--cream);font-style:italic;position:relative}

/* ── NAV BUTTONS ── */
.paper-nav{display:flex;justify-content:space-between;gap:20px;margin-top:80px;padding-top:40px;border-top:1px solid var(--glass-border)}
.paper-nav a{display:flex;flex-direction:column;gap:4px;padding:20px 28px;background:var(--glass);border:1px solid var(--glass-border);text-decoration:none;transition:border-color .2s,background .2s;flex:1;max-width:320px}
.paper-nav a:hover{border-color:var(--gold);background:rgba(200,162,84,.05)}
.nav-dir{font-family:'Helvetica Neue',Arial,sans-serif;font-size:10px;text-transform:uppercase;letter-spacing:3px;color:var(--cream-dim)}
.nav-title{font-size:.95rem;color:var(--cream);margin-top:4px}
.nav-next{text-align:right;margin-left:auto}

/* ── READ ORIGINAL ── */
.read-original{display:inline-flex;align-items:center;gap:8px;margin-top:48px;padding:14px 28px;border:1px solid var(--gold-dim);color:var(--gold);text-decoration:none;font-family:'Helvetica Neue',Arial,sans-serif;font-size:11px;text-transform:uppercase;letter-spacing:2px;transition:background .2s,border-color .2s}
.read-original:hover{background:rgba(200,162,84,.08);border-color:var(--gold)}

/* ── FOOTER ── */
footer{position:relative;z-index:1;text-align:center;padding:40px;border-top:1px solid var(--glass-border);font-family:'Helvetica Neue',Arial,sans-serif;font-size:11px;text-transform:uppercase;letter-spacing:2px;color:var(--cream-dim)}
footer a{color:var(--cream-dim);text-decoration:none}
footer a:hover{color:var(--gold)}

/* ── REVEAL ── */
@keyframes fadeUp{from{opacity:0;transform:translateY(32px)}to{opacity:1;transform:translateY(0)}}
.reveal{opacity:0;transform:translateY(32px);animation:fadeUp .9s ease forwards;animation-timeline:view();animation-range:entry 0% entry 40%}

@media(max-width:768px){
  nav{padding:12px 20px}
  .hero{padding:100px 24px 48px}
  .content-wrap{padding:48px 24px}
  .core-block{padding:28px 24px}
  .paper-nav{flex-direction:column}
  .paper-nav a{max-width:100%}
}
</style>
</head>
<body>

<div class="starfield" id="starfield"></div>

<nav>
  <a href="https://gospel.e5enclave.com/" class="nav-brand">Gospel of Love</a>
  <div class="nav-links">
    <span class="nav-part-badge">{{ paper.part.label }}</span>
    <a href="https://gospel.e5enclave.com/#map">All 196 Papers</a>
    <a href="https://e5enclave.com">E5 Enclave</a>
  </div>
</nav>

<section class="hero">
  <p class="paper-part">{{ paper.part.label }}</p>
  <p class="paper-number">{% if paper.number == 0 %}Foreword{% else %}Paper {{ paper.number }}{% endif %}</p>
  <h1 class="paper-title">{{ paper.title }}</h1>
  <p class="paper-overview">{{ paper.overview }}</p>
</section>

<div class="content-wrap">

  {% if paper.sections.length %}
  <div class="section-block reveal">
    <p class="section-eyebrow">Structure</p>
    <h2 class="section-title">Key Sections</h2>
    <ul class="sections-list">
      {% for s in paper.sections %}
      <li>{{ s }}</li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  <div class="section-block reveal">
    <p class="section-eyebrow">Board Synthesis · Span · E5 Enclave</p>
    <h2 class="section-title">Core Teaching</h2>
    <div class="core-block">
      <p class="core-text">{{ paper.core_teaching }}</p>
    </div>
  </div>

  <div class="reveal">
    <a href="{{ paper.urantia_url }}" target="_blank" rel="noopener" class="read-original">
      ↗ Read the Original Paper · Urantia Foundation
    </a>
  </div>

  <nav class="paper-nav reveal" aria-label="Paper navigation">
    {% if paper.prev != null %}
    <a href="../paper-{{ paper.prev }}/" class="nav-prev">
      <span class="nav-dir">← Previous</span>
      <span class="nav-title">{% if paper.prev == 0 %}Foreword{% else %}Paper {{ paper.prev }} — {{ gospel_papers[paper.prev].title }}{% endif %}</span>
    </a>
    {% else %}<div></div>{% endif %}

    {% if paper.next != null %}
    <a href="../paper-{{ paper.next }}/" class="nav-next">
      <span class="nav-dir">Next →</span>
      <span class="nav-title">Paper {{ paper.next }} — {{ gospel_papers[paper.next].title }}</span>
    </a>
    {% endif %}
  </nav>

</div>

<footer>
  <span>© MMXXVI E5 Enclave Incorporated · Liberty City, Miami</span>
  &nbsp;·&nbsp;
  <a href="https://gospel.e5enclave.com/">Gospel of Love</a>
  &nbsp;·&nbsp;
  <a href="https://e5enclave.com">e5enclave.com</a>
</footer>

<script>
const sf = document.getElementById('starfield');
for(let i=0;i<80;i++){
  const s=document.createElement('div');s.className='star';
  const sz=Math.random()*2+.5;
  s.style.cssText=`width:${sz}px;height:${sz}px;left:${Math.random()*100}%;top:${Math.random()*100}%;opacity:${Math.random()*.5+.1};animation:starDrift ${Math.random()*60+30}s linear ${Math.random()*30}s infinite`;
  sf.appendChild(s);
}
if(!CSS.supports('animation-timeline','view()')){
  const obs=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){e.target.style.animation='fadeUp .9s ease forwards'}})},{threshold:.1});
  document.querySelectorAll('.reveal').forEach(el=>{el.style.opacity='0';obs.observe(el)});
}
</script>
</body>
</html>
