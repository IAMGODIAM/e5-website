---
layout: base.njk
title: "Andrew Joseph Jr. — In Memoriam | E5 Enclave Libations"
description: "A tribute to Andrew Joseph Jr. — Rapid Response Coordinator, Black Lives Matter Grassroots. Father, educator, organizer. Born New Orleans. Transitioned May 16, 2026. Survived by Deanna and Deja."
---

<style>
  /* ─── LIBATION PAGE — ANDREW JOSEPH JR. ─── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --black:    #0a0a0a;
    --offblack: #111111;
    --panel:    #161616;
    --border:   #2a2a2a;
    --gold:     #c9a84c;
    --gold-lt:  #e2c97e;
    --white:    #f5f0e8;
    --muted:    #888;
    --red:      #8b1a1a;
    --serif:    'Georgia', 'Times New Roman', serif;
    --sans:     'Helvetica Neue', Arial, sans-serif;
    --mono:     'Courier New', monospace;
    --max:      1200px;
  }

  body { background: var(--black); color: var(--white); font-family: var(--serif); }

  /* ─── NAV STRIPE ─── */
  .tribute-nav {
    background: var(--offblack);
    border-bottom: 1px solid var(--border);
    padding: 14px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
  .tribute-nav .nav-left {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .tribute-nav .nav-left a { color: var(--gold); text-decoration: none; }
  .tribute-nav .nav-left a:hover { text-decoration: underline; }
  .tribute-nav .nav-left span { color: var(--border); }
  .tribute-nav .nav-right {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* ─── HERO ─── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
  }
  .hero-image-col {
    position: relative;
    overflow: hidden;
  }
  .hero-image-col img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    filter: grayscale(15%) contrast(1.05);
  }
  .hero-image-col::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, transparent 60%, var(--black) 100%);
  }
  .hero-text-col {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 60px 80px 50px;
    position: relative;
    z-index: 1;
  }
  .hero-badge {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .hero-badge::before {
    content: '';
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--gold);
  }
  .hero-name {
    font-family: var(--serif);
    font-size: clamp(42px, 5vw, 72px);
    font-weight: 400;
    line-height: 1.05;
    color: var(--white);
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }
  .hero-role {
    font-family: var(--sans);
    font-size: 13px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 36px;
  }
  .hero-quote {
    font-family: var(--serif);
    font-size: clamp(18px, 2.2vw, 24px);
    font-style: italic;
    line-height: 1.6;
    color: var(--white);
    opacity: 0.9;
    border-left: 2px solid var(--gold);
    padding-left: 24px;
    margin-bottom: 48px;
    max-width: 420px;
  }
  .hero-facts {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px 32px;
    border-top: 1px solid var(--border);
    padding-top: 32px;
    max-width: 420px;
  }
  .hero-fact-label {
    font-family: var(--sans);
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 4px;
  }
  .hero-fact-value {
    font-family: var(--serif);
    font-size: 15px;
    color: var(--white);
  }
  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; min-height: auto; }
    .hero-image-col { height: 60vw; max-height: 480px; }
    .hero-image-col::after { background: linear-gradient(to bottom, transparent 50%, var(--black) 100%); }
    .hero-text-col { padding: 48px 24px; }
    .hero-facts { max-width: 100%; }
  }

  /* ─── PULL QUOTE BAND ─── */
  .pq-band {
    background: var(--panel);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 60px 40px;
    text-align: center;
  }
  .pq-band blockquote {
    font-family: var(--serif);
    font-size: clamp(22px, 3vw, 36px);
    font-style: italic;
    font-weight: 400;
    line-height: 1.5;
    color: var(--white);
    max-width: 820px;
    margin: 0 auto 20px;
  }
  .pq-band cite {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    font-style: normal;
  }

  /* ─── SECTION COMMON ─── */
  .section {
    max-width: var(--max);
    margin: 0 auto;
    padding: 80px 40px;
  }
  .section-eyebrow {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-eyebrow::before {
    content: '';
    display: inline-block;
    width: 20px;
    height: 1px;
    background: var(--gold);
  }
  .section-headline {
    font-family: var(--serif);
    font-size: clamp(32px, 4vw, 54px);
    font-weight: 400;
    line-height: 1.1;
    color: var(--white);
    margin-bottom: 32px;
    letter-spacing: -0.01em;
  }
  .body-lede {
    font-family: var(--serif);
    font-size: clamp(17px, 1.8vw, 20px);
    font-style: italic;
    line-height: 1.75;
    color: var(--white);
    margin-bottom: 28px;
    max-width: 760px;
  }
  .body-para {
    font-family: var(--serif);
    font-size: clamp(15px, 1.5vw, 17px);
    line-height: 1.85;
    color: #ccc;
    margin-bottom: 22px;
    max-width: 760px;
  }
  .body-para strong { color: var(--white); }
  .img-caption {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 10px;
    text-align: center;
  }

  /* ─── TWO-COLUMN READING LAYOUT ─── */
  .reading-grid {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 80px;
    align-items: start;
  }
  .reading-grid .photo-col img {
    width: 100%;
    display: block;
    filter: grayscale(8%) contrast(1.05);
  }
  @media (max-width: 960px) {
    .reading-grid { grid-template-columns: 1fr; gap: 40px; }
  }

  /* ─── VERDICT SECTION ─── */
  .verdict-section {
    background: var(--panel);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .verdict-inner {
    max-width: var(--max);
    margin: 0 auto;
    padding: 80px 40px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }
  .verdict-stat {
    text-align: center;
    padding: 48px;
    border: 1px solid var(--border);
    background: var(--offblack);
  }
  .verdict-number {
    font-family: var(--serif);
    font-size: clamp(64px, 8vw, 120px);
    font-weight: 400;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 8px;
  }
  .verdict-label {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    max-width: 240px;
    margin: 0 auto;
    line-height: 1.6;
  }
  .verdict-quote {
    font-family: var(--serif);
    font-size: clamp(18px, 2vw, 24px);
    font-style: italic;
    line-height: 1.65;
    color: var(--white);
    border-left: 2px solid var(--gold);
    padding-left: 28px;
    margin-top: 32px;
  }
  .verdict-quote cite {
    display: block;
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    font-style: normal;
    margin-top: 16px;
  }
  @media (max-width: 900px) {
    .verdict-inner { grid-template-columns: 1fr; gap: 40px; }
  }

  /* ─── FAMILY SECTION ─── */
  .family-section {
    background: var(--offblack);
    border-top: 1px solid var(--border);
  }
  .survivors-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    margin-top: 48px;
    border: 1px solid var(--border);
  }
  .survivor-card {
    background: var(--panel);
    padding: 32px;
    text-align: center;
  }
  .survivor-role {
    font-family: var(--sans);
    font-size: 9px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 10px;
  }
  .survivor-name {
    font-family: var(--serif);
    font-size: 20px;
    color: var(--white);
  }
  .survivor-note {
    font-family: var(--sans);
    font-size: 11px;
    color: var(--muted);
    margin-top: 6px;
    font-style: italic;
  }
  @media (max-width: 700px) {
    .survivors-grid { grid-template-columns: 1fr; }
  }

  /* ─── TIMELINE ─── */
  .timeline-section {
    background: var(--black);
    border-top: 1px solid var(--border);
  }
  .timeline {
    position: relative;
    margin-top: 56px;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 120px;
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--border);
  }
  .tl-entry {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 0 40px;
    padding: 0 0 48px 0;
    position: relative;
  }
  .tl-entry.major .tl-dot { background: var(--gold); }
  .tl-date {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    text-align: right;
    padding-top: 4px;
    line-height: 1.4;
  }
  .tl-dot {
    position: absolute;
    left: 115px;
    top: 6px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--border);
    border: 1px solid var(--muted);
    z-index: 1;
  }
  .tl-content { padding-left: 24px; }
  .tl-headline {
    font-family: var(--serif);
    font-size: 17px;
    color: var(--white);
    margin-bottom: 6px;
    line-height: 1.3;
  }
  .tl-entry.major .tl-headline { color: var(--gold); }
  .tl-body {
    font-family: var(--serif);
    font-size: 14px;
    line-height: 1.75;
    color: #999;
    max-width: 620px;
  }
  @media (max-width: 700px) {
    .timeline::before { left: 0; }
    .tl-entry { grid-template-columns: 1fr; gap: 4px; }
    .tl-date { text-align: left; padding-left: 20px; }
    .tl-dot { left: -5px; }
    .tl-content { padding-left: 20px; }
  }

  /* ─── PHOTO GALLERY SECTION ─── */
  .gallery-section {
    background: var(--offblack);
    border-top: 1px solid var(--border);
  }
  .photo-masonry {
    columns: 3;
    column-gap: 8px;
    margin-top: 48px;
  }
  .photo-masonry .p-item {
    break-inside: avoid;
    margin-bottom: 8px;
    overflow: hidden;
    position: relative;
    background: var(--panel);
  }
  .photo-masonry .p-item img {
    width: 100%;
    display: block;
    transition: transform 0.4s ease, filter 0.4s ease;
    filter: grayscale(10%) contrast(1.05);
  }
  .photo-masonry .p-item:hover img {
    transform: scale(1.03);
    filter: grayscale(0%) contrast(1.1);
  }
  @media (max-width: 900px) { .photo-masonry { columns: 2; } }
  @media (max-width: 600px) { .photo-masonry { columns: 1; } }

  /* ─── VIDEO SECTION ─── */
  .video-section {
    background: var(--black);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .video-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    margin-top: 48px;
  }
  .video-card {
    background: var(--panel);
    border: 1px solid var(--border);
    overflow: hidden;
  }
  .video-card video,
  .video-card iframe {
    width: 100%;
    display: block;
    aspect-ratio: 16/9;
    background: #000;
    border: none;
  }
  .video-card .video-caption {
    padding: 16px 20px;
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    border-top: 1px solid var(--border);
  }
  @media (max-width: 800px) {
    .video-grid { grid-template-columns: 1fr; }
  }

  /* ─── GRAPHICS / MOVEMENT MOURNS ─── */
  .graphics-section {
    background: var(--panel);
    border-top: 1px solid var(--border);
  }
  .graphics-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin-top: 48px;
  }
  .graphics-grid img {
    width: 100%;
    aspect-ratio: 1/1;
    object-fit: cover;
    display: block;
    filter: grayscale(8%);
    transition: filter 0.3s ease, transform 0.3s ease;
  }
  .graphics-grid img:hover { filter: grayscale(0%); transform: scale(1.02); }
  .memorial-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin-top: 8px;
  }
  .memorial-grid img {
    width: 100%;
    display: block;
    object-fit: cover;
    filter: grayscale(5%);
    transition: filter 0.3s ease;
  }
  .memorial-grid img:hover { filter: grayscale(0%); }
  @media (max-width: 800px) {
    .graphics-grid { grid-template-columns: repeat(2, 1fr); }
    .memorial-grid { grid-template-columns: 1fr; }
  }

  /* ─── AJ3 SON SECTION ─── */
  .son-section {
    background: var(--offblack);
    border-top: 1px solid var(--border);
  }
  .son-inner {
    max-width: var(--max);
    margin: 0 auto;
    padding: 80px 40px;
    display: grid;
    grid-template-columns: 1fr 440px;
    gap: 80px;
    align-items: center;
  }
  .son-photo img {
    width: 100%;
    display: block;
    filter: sepia(10%) contrast(1.05);
  }
  @media (max-width: 960px) {
    .son-inner { grid-template-columns: 1fr; gap: 40px; }
  }

  /* ─── ACTION CARDS ─── */
  .action-section {
    background: var(--black);
    border-top: 1px solid var(--border);
  }
  .action-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    margin-top: 48px;
    border: 1px solid var(--border);
  }
  .action-card {
    background: var(--panel);
    padding: 40px 32px;
    display: flex;
    flex-direction: column;
  }
  .action-card .ac-num {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--gold);
    letter-spacing: 0.1em;
    margin-bottom: 20px;
  }
  .action-card h3 {
    font-family: var(--serif);
    font-size: 22px;
    font-weight: 400;
    color: var(--white);
    margin-bottom: 16px;
    line-height: 1.25;
  }
  .action-card p {
    font-family: var(--serif);
    font-size: 14px;
    line-height: 1.75;
    color: #999;
    flex: 1;
    margin-bottom: 28px;
  }
  .action-link {
    display: inline-block;
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    text-decoration: none;
    border: 1px solid var(--gold);
    padding: 10px 20px;
    transition: background 0.2s, color 0.2s;
    align-self: flex-start;
  }
  .action-link:hover { background: var(--gold); color: var(--black); }
  @media (max-width: 900px) {
    .action-grid { grid-template-columns: 1fr; }
  }

  /* ─── LINEAGE FUND ─── */
  .fund-section {
    background: var(--offblack);
    border-top: 1px solid var(--border);
  }
  .fund-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    margin-top: 48px;
  }
  .fund-panel {
    border: 1px solid var(--border);
    background: var(--panel);
    padding: 40px;
  }
  .fund-panel h3 {
    font-family: var(--serif);
    font-size: 24px;
    font-weight: 400;
    color: var(--white);
    margin-bottom: 8px;
  }
  .fund-panel .fund-sub {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
  }
  .fund-panel p {
    font-family: var(--serif);
    font-size: 14px;
    line-height: 1.75;
    color: #999;
    margin-bottom: 28px;
  }
  .fund-embed {
    margin-top: 16px;
    border: 1px solid var(--border);
    background: #fff;
    min-height: 200px;
    overflow: hidden;
  }
  .fund-embed iframe {
    width: 100%;
    min-height: 400px;
    border: none;
    display: block;
  }
  @media (max-width: 800px) {
    .fund-grid { grid-template-columns: 1fr; }
  }

  /* ─── CLOSING POUR ─── */
  .closing {
    background: var(--black);
    border-top: 1px solid var(--border);
    text-align: center;
    padding: 100px 40px;
  }
  .closing .pour-line {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 32px;
  }
  .closing .pour-text {
    font-family: var(--serif);
    font-size: clamp(22px, 3vw, 36px);
    font-style: italic;
    color: var(--white);
    max-width: 720px;
    margin: 0 auto 24px;
    line-height: 1.6;
  }
  .closing .ase {
    font-family: var(--serif);
    font-size: clamp(28px, 4vw, 48px);
    color: var(--gold);
    letter-spacing: 0.2em;
    margin-top: 32px;
  }
  .closing .record-note {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.15em;
    color: var(--muted);
    margin-top: 40px;
    text-transform: uppercase;
  }
  .closing .record-note span { color: var(--gold); }

  /* ─── DIVIDER ─── */
  .pan-bar {
    height: 3px;
    background: linear-gradient(to right, #006400, #000, #FF0000);
    width: 100%;
  }
</style>

