<script>
  // Memorial wall — localStorage-backed so the family can collect memories
  // over time without needing a server. Entries are scoped per-device.
  (function () {
    const KEY = 'aj-memories-v1';
    const form = document.getElementById('memoryForm');
    const list = document.getElementById('entries');

    function load() {
      try { return JSON.parse(localStorage.getItem(KEY) || '[]'); }
      catch (e) { return []; }
    }
    function save(arr) {
      localStorage.setItem(KEY, JSON.stringify(arr));
    }
    function escapeHTML(s) {
      return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
    }
    function render() {
      const arr = load();
      // Keep the two seeded entries in the DOM; prepend user entries above them.
      const seeded = list.querySelectorAll('.entry.seeded');
      list.innerHTML = '';
      arr.slice().reverse().forEach(item => {
        const el = document.createElement('article');
        el.className = 'entry';
        el.innerHTML =
          '<div class="msg">' + escapeHTML(item.msg) + '</div>' +
          '<div class="byline">' + escapeHTML(item.name) +
            (item.where ? ' · ' + escapeHTML(item.where) : '') +
            ' <span class="when">' + escapeHTML(item.when) + '</span></div>';
        list.appendChild(el);
      });
      seeded.forEach(n => list.appendChild(n));
    }

    // Mark the existing entries as seeded so we keep them on render.
    list.querySelectorAll('.entry').forEach(n => n.classList.add('seeded'));

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      const name = form.name.value.trim();
      const where = form.where.value.trim();
      const msg = form.msg.value.trim();
      if (!name || !msg) return;
      const arr = load();
      const when = new Date().toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
      arr.push({ name, where, msg, when });
      save(arr);
      form.reset();
      render();
    });

    render();
  })();
</script>
