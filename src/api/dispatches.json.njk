---
permalink: /api/dispatches.json
eleventyExcludeFromCollections: true
---
{%- set items = collections.post -%}
[
  {%- for post in items | limit(8) %}
  {
    "title": {{ post.data.title | dump | safe }},
    "date": "{{ post.data.date | isoDate }}",
    "category": {{ (post.data.category or "Dispatch") | dump | safe }},
    "permalink": {{ post.url | dump | safe }},
    "excerpt": {{ (post.data.description or "") | dump | safe }},
    "readTime": {{ (post.data.readTime or "5 min read") | dump | safe }},
    "author": {{ (post.data.author or "E5 Enclave") | dump | safe }}
  }{% if not loop.last %},{% endif %}
  {%- endfor %}
]
