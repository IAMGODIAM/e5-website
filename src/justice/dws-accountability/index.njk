<script>
// ─── TAB SYSTEM ───
function showTab(name, idx) {
  document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('pane-' + name).classList.add('active');
  document.querySelectorAll('.tab-btn')[idx].classList.add('active');
  window.scrollTo({ top: document.querySelector('.tab-bar').offsetTop - 60, behavior: 'smooth' });
}

// ─── POPUP ───
function openSignupPopup() {
  document.getElementById('signupPopup').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeSignupPopup() {
  document.getElementById('signupPopup').classList.remove('open');
  document.body.style.overflow = '';
}
document.getElementById('signupPopup').addEventListener('click', function(e) {
  if (e.target === this) closeSignupPopup();
});

// Show popup after 30-45 seconds if not already signed up
if (!sessionStorage.getItem('dws_signed')) {
  var _delay = Math.floor(Math.random() * 15000) + 30000;
  setTimeout(openSignupPopup, _delay);
}

// ─── FORM SUBMIT ───
document.getElementById('supportForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  const btn = this.querySelector('.submit-btn');
  btn.dataset.origText = btn.textContent;
  btn.textContent = 'Recording...';
  btn.disabled = true;

  const fd = new FormData(this);
  const data = Object.fromEntries(fd.entries());
  data.source = 'dws-accountability-page';

  try {
    const resp = await fetch('https://sue-45c3e283.base44.app/functions/contactForm', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });
    const result = await resp.json().catch(() => ({}));
    if (!resp.ok) throw new Error(result.error || 'Server error ' + resp.status);

    sessionStorage.setItem('dws_signed', '1');
    this.style.display = 'none';
    document.getElementById('successMsg').style.display = 'block';
  } catch (err) {
    console.error('[dws-pledge]', err);
    btn.textContent = btn.dataset.origText || 'Add My Name →';
    btn.disabled = false;
    const errBox = document.getElementById('formError');
    if (errBox) {
      errBox.textContent = err.message || 'Network error. Please try again or email press@e5enclave.com.';
      errBox.style.display = 'block';
    }
  }
});
</script>
