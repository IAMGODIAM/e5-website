<script>
  (function(){
    const el=document.getElementById('liveDate');
    if(!el)return;
    const tick=()=>{ el.textContent=new Date().toLocaleString('en-US',{month:'short',day:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit',hour12:false}); };
    tick();setInterval(tick,30000);
  })();

  (function(){
    const target=new Date('2026-06-01T09:00:00-05:00').getTime();
    const pad=n=>String(Math.max(0,n)).padStart(2,'0');
    function update(){
      const diff=Math.max(0,target-Date.now());
      document.getElementById('cd-days').textContent=pad(Math.floor(diff/86400000));
      document.getElementById('cd-hrs').textContent=pad(Math.floor((diff%86400000)/3600000));
      document.getElementById('cd-min').textContent=pad(Math.floor((diff%3600000)/60000));
      document.getElementById('cd-sec').textContent=pad(Math.floor((diff%60000)/1000));
    }
    update();setInterval(update,1000);
  })();

  (function(){
    const seg=document.getElementById('commitment_seg');
    const hidden=document.getElementById('commitment_type');
    if(!seg||!hidden)return;
    seg.querySelectorAll('.opt').forEach(opt=>{
      opt.addEventListener('click',()=>{
        seg.querySelectorAll('.opt').forEach(o=>o.classList.remove('active'));
        opt.classList.add('active');
        hidden.value=opt.dataset.value;
      });
    });
  })();

  (function(){
    const seg=document.getElementById('lodging_seg');
    const hidden=document.getElementById('needs_lodging');
    if(!seg||!hidden)return;
    seg.querySelectorAll('.opt').forEach(opt=>{
      opt.addEventListener('click',()=>{
        seg.querySelectorAll('.opt').forEach(o=>o.classList.remove('active'));
        opt.classList.add('active');
        hidden.value=opt.dataset.value;
      });
    });
  })();

  (function(){
    const ENDPOINT='https://sue-app-e73f9f1e.base44.app/functions/karmeloSignup';
    const form=document.getElementById('signupForm');
    const btn=document.getElementById('submitBtn');
    const errorMsg=document.getElementById('errorMsg');
    const successBox=document.getElementById('successBox');
    if(!form)return;
    form.addEventListener('submit',async function(e){
      e.preventDefault();
      errorMsg.style.display='none';
      errorMsg.textContent='';
      btn.disabled=true;
      btn.innerHTML='Submitting… <span class="arrow">→</span>';
      const v=id=>(document.getElementById(id)||{}).value||'';
      const payload={
        first_name:v('first_name'),last_name:v('last_name'),email:v('email'),
        phone:v('phone'),city:v('city'),state:v('state').toUpperCase(),
        zip:'',commitment_type:v('commitment_type'),availability:v('availability'),
        can_travel:document.getElementById('can_travel').checked,
        needs_lodging:v('needs_lodging'),skills_to_offer:v('skills_to_offer'),message:v('message'),
        source:'e5enclave-justice-karmelo'
      };
      try{
        const res=await fetch(ENDPOINT,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
        const data=await res.json().catch(()=>({}));
        if(res.ok&&data&&data.success){
          form.style.display='none';
          successBox.style.display='block';
          window.scrollTo({top:successBox.getBoundingClientRect().top+window.scrollY-80,behavior:'smooth'});
        }else{
          errorMsg.textContent=(data&&data.error)?data.error:'Something went wrong. Please try again.';
          errorMsg.style.display='block';
          btn.disabled=false;
          btn.innerHTML='Sign My Name — I Stand With Karmelo <span class="arrow">→</span>';
        }
      }catch(err){
        errorMsg.textContent='Network error. Please check your connection and try again.';
        errorMsg.style.display='block';
        btn.disabled=false;
        btn.innerHTML='Sign My Name — I Stand With Karmelo <span class="arrow">→</span>';
      }
    });
  })();
</script>
