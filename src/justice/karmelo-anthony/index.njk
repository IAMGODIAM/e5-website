<link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800;900&family=Geist+Mono:wght@400;500;600&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />

<style>

  :root {
    --bg:        #000000;
    --bg-1:      #0a0a0a;
    --bg-2:      #111111;
    --fg:        #ededed;
    --fg-dim:    #a1a1a1;
    --fg-dimmer: #6b6b6b;
    --fg-ghost:  #3a3a3a;
    --border:    #1c1c1c;
    --border-2:  #2a2a2a;
    --border-3:  #3f3f3f;
    --accent:    #ffffff;
    --signal:    #ff4d4d;
    --signal-2:  #ff7a3d;

    --sans: 'Geist', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --mono: 'Geist Mono', ui-monospace, 'SF Mono', 'Menlo', monospace;
    --serif: 'Instrument Serif', 'Times New Roman', serif;

    --container: 1280px;
    --gutter: 32px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }

  body {
    background: var(--bg);
    color: var(--fg);
    font-family: var(--sans);
    font-feature-settings: "ss01", "ss03", "cv11";
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
    line-height: 1.5;
    overflow-x: hidden;
  }

  ::selection { background: var(--fg); color: var(--bg); }

  a { color: inherit; text-decoration: none; }

  /* ───────── LAYOUT PRIMITIVES ───────── */
  .wrap {
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 var(--gutter);
    position: relative;
  }

  .rule { border: 0; border-top: 1px solid var(--border); margin: 0; }

  .mono {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-dim);
  }

  /* ───────── TICKER BAR ───────── */
  .ticker {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(0,0,0,0.85);
    backdrop-filter: blur(12px) saturate(140%);
    -webkit-backdrop-filter: blur(12px) saturate(140%);
    border-bottom: 1px solid var(--border);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--fg-dim);
  }
  .ticker-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 40px;
    gap: 16px;
    white-space: nowrap;
    overflow: hidden;
  }
  .ticker-left, .ticker-right { display: flex; align-items: center; gap: 18px; min-width: 0; }
  .ticker-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 2px 0;
    color: var(--fg);
  }
  .ticker-pill .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--signal);
    box-shadow: 0 0 0 0 rgba(255,77,77,0.55);
    animation: pulse 1.8s infinite;
  }
  .ticker-divider { color: var(--fg-ghost); }
  @keyframes pulse {
    0%   { box-shadow: 0 0 0 0 rgba(255,77,77,0.6); }
    70%  { box-shadow: 0 0 0 8px rgba(255,77,77,0); }
    100% { box-shadow: 0 0 0 0 rgba(255,77,77,0); }
  }
  @media (max-width: 720px) {
    .ticker-right { display: none; }
  }

  /* ───────── NAV ───────── */
  .nav {
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .brand {
    display: flex; align-items: center; gap: 12px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg);
  }
  .brand-mark {
    width: 28px; height: 28px;
    border: 1px solid var(--border-3);
    display: grid; place-items: center;
    font-family: var(--sans);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: -0.02em;
    color: var(--fg);
  }
  .brand-mark span { color: var(--fg-dimmer); }

  .nav-links {
    display: flex; align-items: center; gap: 28px;
  }
  .nav-links a {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--fg-dim);
    transition: color .15s ease;
  }
  .nav-links a:hover { color: var(--fg); }
  .nav-cta {
    border: 1px solid var(--border-3);
    padding: 8px 14px;
    color: var(--fg) !important;
    transition: background .15s ease, border-color .15s ease;
  }
  .nav-cta:hover { background: var(--fg); color: var(--bg) !important; border-color: var(--fg); }

  @media (max-width: 720px) {
    .nav-links a:not(.nav-cta) { display: none; }
  }

  /* ───────── HERO ───────── */
  .hero {
    position: relative;
    padding: 96px 0 64px;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background-image:
      linear-gradient(to right, rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 80px 80px;
    background-position: center top;
    mask-image: radial-gradient(ellipse at 50% 30%, #000 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse at 50% 30%, #000 30%, transparent 75%);
    pointer-events: none;
  }
  .hero::after {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(60% 60% at 50% 0%, rgba(255,255,255,0.06), transparent 60%),
      radial-gradient(40% 40% at 80% 20%, rgba(255,77,77,0.05), transparent 70%);
    pointer-events: none;
  }
  .hero-inner { position: relative; }

  .eyebrow {
    display: inline-flex; align-items: center; gap: 10px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-dim);
    padding: 6px 12px;
    border: 1px solid var(--border-2);
    border-radius: 999px;
    background: var(--bg-1);
  }
  .eyebrow .glyph { color: var(--fg); }

  .hero h1 {
    font-family: var(--sans);
    font-weight: 600;
    font-size: clamp(56px, 11.5vw, 184px);
    line-height: 0.92;
    letter-spacing: -0.055em;
    margin: 28px 0 32px;
    color: var(--fg);
  }
  .hero h1 .italic {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--fg);
  }
  .hero h1 .dim { color: var(--fg-dimmer); }

  .hero-sub {
    max-width: 720px;
    font-size: clamp(17px, 1.6vw, 21px);
    line-height: 1.5;
    color: var(--fg-dim);
    margin-bottom: 40px;
  }
  .hero-sub strong { color: var(--fg); font-weight: 600; }

  .cta-row {
    display: flex; flex-wrap: wrap; gap: 12px; align-items: center;
    margin-bottom: 56px;
  }

  .btn {
    display: inline-flex; align-items: center; gap: 10px;
    font-family: var(--sans);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.005em;
    padding: 13px 20px;
    border-radius: 8px;
    border: 1px solid transparent;
    cursor: pointer;
    transition: background .15s ease, color .15s ease, border-color .15s ease, transform .1s ease;
    line-height: 1;
  }
  .btn-primary {
    background: var(--fg);
    color: var(--bg);
    border-color: var(--fg);
  }
  .btn-primary:hover { background: #fff; transform: translateY(-1px); }
  .btn-ghost {
    background: transparent;
    color: var(--fg);
    border-color: var(--border-3);
  }
  .btn-ghost:hover { border-color: var(--fg); background: var(--bg-1); }
  .btn .arrow {
    font-family: var(--mono);
    font-size: 14px;
    transform: translateX(0);
    transition: transform .15s ease;
  }
  .btn:hover .arrow { transform: translateX(3px); }

  /* hero metadata strip */
  .case-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .case-strip .cell {
    padding: 24px 22px;
    border-right: 1px solid var(--border);
    display: flex; flex-direction: column; gap: 10px;
    min-height: 110px;
  }
  .case-strip .cell:last-child { border-right: 0; }
  .case-strip .k {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fg-dimmer);
  }
  .case-strip .v {
    font-family: var(--sans);
    font-size: 17px;
    font-weight: 500;
    color: var(--fg);
    letter-spacing: -0.01em;
    line-height: 1.25;
  }
  .case-strip .v .sub {
    display: block;
    font-family: var(--mono);
    font-size: 11.5px;
    letter-spacing: 0.04em;
    color: var(--fg-dim);
    margin-top: 4px;
    font-weight: 400;
    text-transform: none;
  }
  @media (max-width: 880px) {
    .case-strip { grid-template-columns: repeat(2, 1fr); }
    .case-strip .cell:nth-child(2) { border-right: 0; }
    .case-strip .cell:nth-child(1), .case-strip .cell:nth-child(2) {
      border-bottom: 1px solid var(--border);
    }
  }

  /* ───────── COUNTDOWN STRIPE ───────── */
  .countdown {
    border-bottom: 1px solid var(--border);
    background:
      linear-gradient(180deg, rgba(255,77,77,0.04), transparent 80%),
      var(--bg);
    padding: 56px 0 64px;
  }
  .countdown-grid {
    display: grid;
    grid-template-columns: 1.1fr 2fr;
    gap: 48px;
    align-items: end;
  }
  .countdown-label .mono { color: var(--signal); margin-bottom: 16px; display: inline-block; }
  .countdown-label h2 {
    font-family: var(--sans);
    font-weight: 500;
    font-size: clamp(28px, 3.4vw, 44px);
    letter-spacing: -0.035em;
    line-height: 1.05;
    color: var(--fg);
  }
  .countdown-label h2 em {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    color: var(--fg-dim);
  }

  .clock {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border: 1px solid var(--border-2);
    border-radius: 12px;
    overflow: hidden;
    background: var(--bg-1);
  }
  .clock .unit {
    padding: 22px 18px 18px;
    border-right: 1px solid var(--border);
    display: flex; flex-direction: column; gap: 10px;
    position: relative;
  }
  .clock .unit:last-child { border-right: 0; }
  .clock .num {
    font-family: var(--mono);
    font-weight: 500;
    font-size: clamp(40px, 6.4vw, 84px);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--fg);
    font-variant-numeric: tabular-nums;
  }
  .clock .lbl {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-dim);
  }
  @media (max-width: 880px) {
    .countdown-grid { grid-template-columns: 1fr; gap: 32px; }
    .clock .unit { padding: 18px 14px 14px; }
  }
  @media (max-width: 520px) {
    .clock { grid-template-columns: repeat(2, 1fr); }
    .clock .unit:nth-child(2) { border-right: 0; }
    .clock .unit:nth-child(1), .clock .unit:nth-child(2) { border-bottom: 1px solid var(--border); }
  }

  /* ───────── SECTION HEADER (§) ───────── */
  .section {
    padding: 96px 0;
    border-bottom: 1px solid var(--border);
    position: relative;
  }
  .section.tight { padding: 72px 0; }
  .section-head {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 48px;
    align-items: baseline;
    margin-bottom: 56px;
  }
  .section-head .meta {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-dim);
    position: sticky;
    top: 80px;
  }
  .section-head .meta .num {
    color: var(--fg);
    display: block;
    margin-bottom: 6px;
    font-size: 13px;
  }
  .section-head h2 {
    font-family: var(--sans);
    font-weight: 500;
    font-size: clamp(32px, 4.6vw, 60px);
    letter-spacing: -0.04em;
    line-height: 1.02;
    color: var(--fg);
    max-width: 900px;
  }
  .section-head h2 em {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    color: var(--fg-dim);
  }
  @media (max-width: 880px) {
    .section-head { grid-template-columns: 1fr; gap: 18px; }
    .section-head .meta { position: static; }
  }

  /* ───────── EDITORIAL BODY ───────── */
  .editorial {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: 48px;
  }
  .editorial .col-meta {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-dimmer);
    line-height: 1.7;
  }
  .editorial .col-meta .item { margin-bottom: 16px; }
  .editorial .col-meta .item b { display: block; color: var(--fg-dim); font-weight: 500; margin-bottom: 2px; }

  .editorial .col-body { max-width: 720px; }
  .editorial .col-body p {
    font-size: 18px;
    line-height: 1.65;
    color: #cfcfcf;
    margin-bottom: 22px;
    letter-spacing: -0.005em;
  }
  .editorial .col-body p:first-of-type::first-letter {
    font-family: var(--serif);
    font-weight: 400;
    font-style: normal;
    font-size: 78px;
    line-height: 0.85;
    float: left;
    padding: 6px 14px 0 0;
    color: var(--fg);
  }
  .editorial .col-body p strong {
    color: var(--fg);
    font-weight: 600;
  }
  .editorial .col-body p em {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    color: var(--fg);
    font-size: 1.05em;
  }
  .pullquote {
    border-left: 2px solid var(--fg);
    margin: 36px 0;
    padding: 6px 0 6px 24px;
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: 28px;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--fg);
  }
  .pullquote cite {
    display: block;
    margin-top: 16px;
    font-family: var(--mono);
    font-style: normal;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-dim);
  }
  @media (max-width: 880px) {
    .editorial { grid-template-columns: 1fr; gap: 24px; }
    .editorial .col-body p:first-of-type::first-letter { font-size: 56px; padding: 4px 10px 0 0; }
  }

  /* ───────── FACTS GRID ───────── */
  .facts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--border);
    border-left: 1px solid var(--border);
    margin-top: 64px;
  }
  .fact {
    padding: 32px 28px;
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    display: flex; flex-direction: column; gap: 14px;
    background: var(--bg);
    transition: background .2s ease;
  }
  .fact:hover { background: var(--bg-1); }
  .fact .ix {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--fg-dim);
    display: flex; justify-content: space-between;
  }
  .fact .ix .tag { color: var(--fg-dimmer); }
  .fact .claim {
    font-family: var(--sans);
    font-weight: 500;
    font-size: 21px;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: var(--fg);
  }
  .fact .src {
    margin-top: auto;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--fg-dimmer);
    text-transform: uppercase;
  }
  @media (max-width: 980px) { .facts { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .facts { grid-template-columns: 1fr; } }

  /* ───────── LEGAL BRIEF ───────── */
  .brief {
    border: 1px solid var(--border-2);
    border-radius: 14px;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.02), transparent 60%),
      var(--bg-1);
    padding: 0;
    overflow: hidden;
  }
  .brief-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 24px;
    border-bottom: 1px solid var(--border);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-dim);
  }
  .brief-head .left { display: flex; gap: 12px; align-items: center; }
  .brief-head .stamp {
    display: inline-flex; align-items: center; gap: 6px;
    color: var(--signal);
  }
  .brief-head .stamp .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--signal); }
  .brief-body { padding: 36px 32px 40px; }
  .brief-grid {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 32px;
    padding: 22px 0;
    border-top: 1px solid var(--border);
  }
  .brief-grid:first-child { border-top: 0; padding-top: 0; }
  .brief-grid .label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-dim);
    line-height: 1.6;
  }
  .brief-grid .label .cite { display: block; color: var(--fg-dimmer); margin-top: 4px; }
  .brief-grid .arg {
    font-size: 17px;
    line-height: 1.6;
    color: #d7d7d7;
    letter-spacing: -0.005em;
  }
  .brief-grid .arg strong { color: var(--fg); font-weight: 600; }
  .brief-grid .arg em {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    color: var(--fg);
    font-size: 1.05em;
  }
  @media (max-width: 720px) {
    .brief-grid { grid-template-columns: 1fr; gap: 12px; }
    .brief-body { padding: 26px 22px 30px; }
  }

  /* ───────── FORM ───────── */
  .form-section {
    padding: 96px 0 120px;
    position: relative;
  }
  .form-shell {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 64px;
    align-items: start;
  }
  .form-aside {
    position: sticky;
    top: 80px;
  }
  .form-aside .eyebrow { margin-bottom: 22px; }
  .form-aside h2 {
    font-family: var(--sans);
    font-weight: 500;
    font-size: clamp(36px, 4.4vw, 56px);
    line-height: 1.0;
    letter-spacing: -0.045em;
    color: var(--fg);
    margin-bottom: 22px;
  }
  .form-aside h2 em {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    color: var(--fg-dim);
  }
  .form-aside p {
    font-size: 16px;
    color: var(--fg-dim);
    line-height: 1.6;
    max-width: 420px;
    margin-bottom: 26px;
  }
  .form-aside .meta-list {
    border-top: 1px solid var(--border);
    margin-top: 24px;
  }
  .form-aside .meta-list .row {
    display: flex; justify-content: space-between;
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
    font-family: var(--mono);
    font-size: 11.5px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .form-aside .meta-list .row .k { color: var(--fg-dim); }
  .form-aside .meta-list .row .v { color: var(--fg); }

  .form-card {
    border: 1px solid var(--border-2);
    border-radius: 14px;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.018), transparent 50%),
      var(--bg-1);
    padding: 36px;
  }
  .form-card-head {
    display: flex; justify-content: space-between; align-items: center;
    padding-bottom: 22px;
    margin-bottom: 26px;
    border-bottom: 1px solid var(--border);
  }
  .form-card-head .t {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-dim);
  }
  .form-card-head .step {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--fg-dimmer);
    text-transform: uppercase;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .field { display: flex; flex-direction: column; gap: 8px; }
  .field.full { grid-column: 1 / -1; }
  .field.third { grid-column: span 1; }

  label.f-label {
    font-family: var(--mono);
