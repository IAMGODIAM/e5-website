<script>
// ─── TAB SYSTEM ───
function showTab(name, idx) {
  document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('pane-' + name).classList.add('active');
  document.querySelectorAll('.tab-btn')[idx].classList.add('active');
  window.scrollTo({ top: document.querySelector('.tab-bar').offsetTop - 60, behavior: 'smooth' });
}

// ─── TRIAL COUNTDOWN ───
function updateCountdown() {
  const trial = new Date('2026-06-01T09:00:00-05:00');
  const now = new Date();
  const diff = trial - now;
  if (diff <= 0) return;
  const d = Math.floor(diff / 86400000);
  const h = Math.floor((diff % 86400000) / 3600000);
  const m = Math.floor((diff % 3600000) / 60000);
  const s = Math.floor((diff % 60000) / 1000);
  const ticker = document.querySelector('.ticker-pill');
  if (ticker) ticker.innerHTML = `<span class="dot"></span> Trial in ${d}d ${h}h ${m}m ${s}s · June 1, 2026`;
}
setInterval(updateCountdown, 1000);
updateCountdown();

// ─── FORM SUBMISSION ───
document.getElementById('supportForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  const fd = new FormData(this);
  const data = Object.fromEntries(fd.entries());
  data.source = 'karmelo-justice-page';

  const btn = this.querySelector('.submit-btn');
  btn.textContent = 'Recording...';
  btn.disabled = true;

  try {
    const resp = await fetch('https://sue-45c3e283.base44.app/functions/karmeloSignup', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });

    const result = await resp.json().catch(() => ({}));

    if (!resp.ok) {
      throw new Error(result.error || 'Server error ' + resp.status);
    }

    document.getElementById('supportForm').style.display = 'none';
    document.getElementById('successMsg').style.display = 'block';

    // Update supporter count if returned
    if (result.total_supporters) {
      const counter = document.getElementById('supporterCount');
      if (counter) counter.textContent = result.total_supporters;
    }
  } catch (err) {
    console.error('[karmelo-signup]', err);
    btn.textContent = 'Add My Name to the Record →';
    btn.disabled = false;
    const errBox = document.getElementById('formError');
    if (errBox) {
      errBox.textContent = err.message || 'Network error. Please try again or email israel@e5enclave.com.';
      errBox.style.display = 'block';
    }
  }
});

console.log('People v. Anthony · Forensic Edition · E5 Enclave BDI · May 21, 2026');
console.log('Factual corrections applied. All sources on the public record.');
</script>