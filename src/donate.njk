      <div class="amount-grid" style="display:grid; grid-template-columns:repeat(3, 1fr); gap:12px;">
        {% for amt in [25, 50, 100, 250, 500, 1000] %}
        <button type="button" class="amount-btn{% if amt == 100 %} selected{% endif %}" data-amount="{{ amt }}" aria-pressed="{% if amt == 100 %}true{% else %}false{% endif %}"
