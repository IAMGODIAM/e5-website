  <div class="vc-founder-sig">
    <span class="sig-name">Israel Lee Armstead</span>
    <span class="sig-title">Chairman &amp; Founder · E5 Enclave Incorporated</span>
    <span class="sig-place">Liberty City, Miami, Florida</span>
  </div>
</div>

