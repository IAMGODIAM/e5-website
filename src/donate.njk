          {% set labels = { '25': 'Sustain', '50': 'Build', '100': 'Anchor', '250': 'Steward', '500': 'Transform', '1000': 'Patron' } %}
          <span style="display:block; margin-top:8px; font-family:var(--vc-text); font-size:9.5px; letter-spacing:0.42em; text-transform:uppercase; color:var(--vc-muted); font-weight:600;">{{ labels[amt|string] }}</span>
