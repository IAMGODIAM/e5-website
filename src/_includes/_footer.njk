<footer class="vc-foot">
  {% include "_seal.njk" %}

  {# === BAND 1: Newsletter — light, clean, editorial === #}
  <div style="border-top:1.5px solid var(--vc-ink); padding:40px 56px; display:flex; align-items:center; justify-content:space-between; gap:32px; flex-wrap:wrap; background:var(--vc-bone-2);">
    <div style="flex:1; min-width:240px;">
      <div style="font-family:var(--vc-text); font-size:9.5px; letter-spacing:0.42em; text-transform:uppercase; color:var(--vc-oxblood); font-weight:600; margin-bottom:8px;">Dispatches from the Coalition</div>
      <p style="font-family:var(--vc-display); font-size:20px; color:var(--vc-ink); margin:0; line-height:1.3;">Stay in the record.</p>
      <p style="font-family:var(--vc-display); font-size:15px; color:var(--vc-ink-3); margin:8px 0 0; line-height:1.5;">Research, program updates, and coalition intelligence — twice a month at most.</p>
    </div>
    <form style="display:flex; gap:10px; flex:1; min-width:260px; max-width:440px;" data-vc-form data-subject="newsletter-signup-footer" data-endpoint="/api/contact" novalidate>
      <input type="email" name="email" placeholder="your@email.com" required autocomplete="email" aria-label="Email for newsletter"
        style="flex:1; padding:13px 16px; border:1.5px solid var(--vc-rule); background:var(--vc-bone); font-family:var(--vc-display); font-size:15px; color:var(--vc-ink);"/>
      <button type="submit" class="vc-cta-primary" style="white-space:nowrap; padding:13px 22px;">Subscribe →</button>
    </form>
  </div>

  {# === BAND 2: Donation CTA — dark, sovereign, weighted === #}
  <div style="background:var(--vc-ink); padding:40px 56px; display:flex; align-items:center; justify-content:space-between; gap:32px; flex-wrap:wrap;">
    <div style="flex:1; min-width:240px;">
      <div style="font-family:var(--vc-text); font-size:9.5px; letter-spacing:0.42em; text-transform:uppercase; color:var(--vc-oxblood); font-weight:600; margin-bottom:8px;">Support the Work · 501(c)(3) · EIN 99-3822441</div>
      <p style="font-family:var(--vc-display); font-size:20px; color:var(--vc-bone); margin:0; line-height:1.3;">The record is built by those who <em style="color:var(--vc-gold-2);">sustain it.</em></p>
      <p style="font-family:var(--vc-display); font-size:15px; color:rgba(232,213,163,0.65); margin:8px 0 0; line-height:1.5;">Tax-deductible. Every dollar funds Black community development in Liberty City.</p>
    </div>
    <div style="display:flex; gap:16px; flex-wrap:wrap; align-items:center;">
      <a href="/donate/" class="vc-cta-primary" style="background:var(--vc-oxblood); padding:13px 28px; font-size:15px; white-space:nowrap;">Donate to E5 Enclave →</a>
      <a href="/coalition/apply/" style="font-family:var(--vc-display); font-size:15px; color:rgba(232,213,163,0.7); text-decoration:none; border-bottom:1px solid rgba(232,213,163,0.25); padding-bottom:2px; white-space:nowrap;">Join the Coalition →</a>
    </div>
  </div>

  <div class="vc-foot-grid">
    <div class="colophon">
      <strong>Colophon</strong>
      Convened in {{ site.established.city }}, Florida. Set in Cormorant Garamond &amp; Inter. Printed for the Coalition of the Willing, founded {{ site.established.date }}.
    </div>
    <div>
      <h4>The Record</h4>
      <ul>
        {% for paper in collections.paper -%}
        <li><a href="{{ paper.url }}">{{ paper.data.title }}</a></li>
        {%- endfor %}
      </ul>
    </div>
    <div>
      <h4>Departments</h4>
      <ul>
        <li><a href="/doctrine/">Doctrine</a></li>
        <li><a href="/pillars/">The Five Pillars</a></li>
        <li><a href="/record/">The Record</a></li>
        <li><a href="/restitution-246/">Restitution 246</a></li>
        <li><a href="/press/">Press</a></li>
        <li><a href="/blog/">Dispatches</a></li>
      </ul>
    </div>
    <div>
      <h4>Programs</h4>
      <ul>
        {% for prog in collections.program -%}
        <li><a href="{{ prog.url }}">{{ prog.data.title or prog.data.name }}</a></li>
        {%- endfor %}
        <li><a href="/first-offering/">First Offering</a></li>
      </ul>
    </div>
    <div>
      <h4>The Coalition</h4>
      <ul>
        <li><a href="/coalition/">Members</a></li>
        <li><a href="/coalition/apply/">Apply</a></li>
        <li><a href="/volunteer/">Volunteer</a></li>
        <li><a href="/founding-address/">Founding Address</a></li>
        <li><a href="/donate/">Donate</a></li>
        <li><a href="/contact/">Contact</a></li>
      </ul>
    </div>
    <div>
      <h4>Institutional</h4>
      <ul>
        <li><a href="/contracts-grants/">Contracts &amp; Grants</a></li>
        <li><a href="/contracts-grants/#federal">Federal: UEI H8NGXEYE2HH8</a></li>
        <li><a href="/contracts-grants/#federal">CAGE: 07E88</a></li>
        <li><a href="/governance/">Governance</a></li>
        <li><a href="/faq/">FAQ</a></li>
      </ul>
    </div>
  </div>
  <div class="vc-foot-fine">
    <span>© MMXXVI <em>{{ site.fullName }}</em></span>
    <span>Founded {{ site.established.date }} · {{ site.established.city }}</span>
    <span>EIN 99-3822441 · 501(c)(3)</span>
    <span>For the next thousand years</span>
  </div>
  <div class="vc-foot-fine" style="border-top:0; padding-top:8px;">
    <span><a href="/faq/">FAQ</a></span>
    <span><a href="/privacy-policy/">Privacy</a></span>
    <span><a href="/terms-of-service/">Terms</a></span>
    <span><a href="/contracts-grants/">Federal Procurement</a></span>
  </div>
</footer>