<div class="vc-foot-seal reveal" role="img" aria-label="{{ site.name }} Coalition Seal">
  <svg class="vc-foot-seal-svg" viewBox="0 0 320 320" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
    {# Concentric rings — palette-aware via stroke="currentColor" plus explicit fallbacks #}
    <circle class="ring-slow" cx="160" cy="160" r="148" fill="none" stroke="var(--vc-ink)" stroke-width="1.2"/>
    <circle class="ring-breath" cx="160" cy="160" r="138" fill="none" stroke="var(--vc-oxblood)" stroke-width="0.5" opacity="0.45"/>
    <circle class="ring-mid" cx="160" cy="160" r="100" fill="none" stroke="var(--vc-ink)" stroke-width="0.3" opacity="0.16"/>
    <circle class="ring-breath" cx="160" cy="160" r="62" fill="none" stroke="var(--vc-oxblood)" stroke-width="0.5" opacity="0.4"/>

    <polygon class="mesh-poly" points="260,160 246.6,110 210,73.4 160,60 110,73.4 73.4,110 60,160 73.4,210 110,246.6 160,260 210,246.6 246.6,210"
      fill="none" stroke="var(--vc-ink)" stroke-width="0.4" opacity="0.18"/>

    <g stroke="var(--vc-oxblood)" stroke-width="0.5" opacity="0.42" fill="none">
      <line class="mesh-spoke" x1="160" y1="160" x2="260" y2="160"/>
      <line class="mesh-spoke" x1="160" y1="160" x2="210" y2="73.4"/>
      <line class="mesh-spoke" x1="160" y1="160" x2="110" y2="73.4"/>
      <line class="mesh-spoke" x1="160" y1="160" x2="60" y2="160"/>
      <line class="mesh-spoke" x1="160" y1="160" x2="110" y2="246.6"/>
      <line class="mesh-spoke" x1="160" y1="160" x2="210" y2="246.6"/>
    </g>

    <g fill="var(--vc-oxblood)">
      <circle class="mesh-node-active" cx="260" cy="160" r="3.5"/>
      <circle class="mesh-node-active" cx="210" cy="73.4" r="3.5"/>
      <circle class="mesh-node-active" cx="110" cy="73.4" r="3.5"/>
      <circle class="mesh-node-active" cx="60" cy="160" r="3.5"/>
      <circle class="mesh-node-active" cx="110" cy="246.6" r="3.5"/>
      <circle class="mesh-node-active" cx="210" cy="246.6" r="3.5"/>
    </g>

    <g fill="var(--vc-bone)" stroke="var(--vc-ink)" stroke-width="0.8">
      <circle cx="246.6" cy="110" r="2.6"/>
      <circle cx="160" cy="60" r="2.6"/>
      <circle cx="73.4" cy="110" r="2.6"/>
      <circle cx="73.4" cy="210" r="2.6"/>
      <circle cx="160" cy="260" r="2.6"/>
      <circle cx="246.6" cy="210" r="2.6"/>
    </g>

    <circle cx="160" cy="160" r="48" fill="var(--vc-bone)" stroke="var(--vc-ink)" stroke-width="0.8"/>
    <text x="160" y="178" text-anchor="middle" font-family="Cormorant Garamond, serif" font-weight="500" fill="var(--vc-ink)">
      <tspan font-size="44">E</tspan>
      <tspan font-size="34" font-style="italic" fill="var(--vc-oxblood)" dx="-2" dy="-5">5</tspan>
    </text>
  </svg>
  <div class="vc-foot-seal-name">Enclave</div>
  <div class="vc-foot-seal-sub">— Sealed in {{ site.established.city }} · For the next thousand years —</div>
</div>
