<section class="vc-counter" aria-label="Coalition register">
  <div class="vc-counter-grid">
    <div class="vc-counter-cell">
      <div class="vc-counter-lbl">Supporters of record</div>
      <div class="vc-counter-num" data-counter-target="{{ site.counters.supporters }}">0</div>
      <div class="vc-counter-meta">individuals on the rolls</div>
    </div>
    <div class="vc-counter-orn" aria-hidden="true"></div>
    <div class="vc-counter-cell">
      <div class="vc-counter-lbl">Member organizations</div>
      <div class="vc-counter-num" data-counter-target="{{ site.counters.memberOrgs }}">0</div>
      <div class="vc-counter-meta">institutions of the Coalition</div>
    </div>
    <div class="vc-counter-orn" aria-hidden="true"></div>
    <div class="vc-counter-cell">
      <div class="vc-counter-lbl">Pillars in motion</div>
      <div class="vc-counter-num" data-counter-target="{{ site.counters.pillars }}">0</div>
      <div class="vc-counter-meta">the structure of the remedy</div>
    </div>
  </div>
</section>
