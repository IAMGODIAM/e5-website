<section class="vc-trust-rail" aria-label="Organizational credentials">
  <div class="vc-trust-inner">
    <div class="vc-trust-tile" data-type="ein">
      <span class="vc-trust-lbl">EIN</span>
      <span class="vc-trust-val">{{ site.ein }}</span>
      <span class="vc-trust-sub">IRS Employer ID</span>
    </div>
    <div class="vc-trust-div" aria-hidden="true"></div>
    <div class="vc-trust-tile" data-type="sam">
      <span class="vc-trust-lbl">SAM.gov UEI</span>
      <span class="vc-trust-val">H8NGXEYE2HH8</span>
      <span class="vc-trust-sub">Federal Registrant</span>
    </div>
    <div class="vc-trust-div" aria-hidden="true"></div>
    <div class="vc-trust-tile" data-type="irs">
      <span class="vc-trust-lbl">IRS Status</span>
      <span class="vc-trust-val">501(c)(3)</span>
      <span class="vc-trust-sub">Public Charity · Confirmed</span>
    </div>
    <div class="vc-trust-div" aria-hidden="true"></div>
    <div class="vc-trust-tile" data-type="founded">
      <span class="vc-trust-lbl">Founded</span>
      <span class="vc-trust-val">June 2024</span>
