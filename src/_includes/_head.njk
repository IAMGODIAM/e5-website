<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>{% if title %}{{ title }} — {{ site.name }}{% else %}{{ site.name }} — {{ site.tagline }}{% endif %}</title>
<meta name="description" content="{{ description or site.description or (site.name + ' — ' + site.tagline) }}"/>
<link rel="canonical" href="{{ site.url }}{{ page.url }}"/>
<meta name="theme-color" content="{{ site.themeColor }}"/>

{# Google Search Console Verification #}
{% if site.googleVerification %}<meta name="google-site-verification" content="{{ site.googleVerification }}"/>{% endif %}

{# Open Graph / Twitter #}
<meta property="og:type" content="{{ ogType or 'website' }}"/>
<meta property="og:site_name" content="{{ site.name }}"/>
<meta property="og:title" content="{{ title or (site.name + ' — ' + site.tagline) }}"/>
<meta property="og:description" content="{{ description or site.description or (site.name + ' — ' + site.tagline) }}"/>
<meta property="og:url" content="{{ site.url }}{{ page.url }}"/>
<meta property="og:locale" content="en_US"/>
<meta property="og:image" content="{{ site.url }}{{ ogImage or site.ogImage }}"/>
<meta property="og:image:width" content="1200"/>
<meta property="og:image:height" content="630"/>
<meta name="twitter:card" content="summary_large_image"/>
<meta name="twitter:title" content="{{ title or (site.name + ' — ' + site.tagline) }}"/>
<meta name="twitter:description" content="{{ description or site.description or (site.name + ' — ' + site.tagline) }}"/>
<meta name="twitter:image" content="{{ site.url }}{{ ogImage or site.ogImage }}"/>

{# Favicons #}
<link rel="icon" type="image/x-icon" href="/favicon.ico"/>
<link rel="icon" type="image/svg+xml" href="/assets/img/favicon/favicon.svg"/>
<link rel="apple-touch-icon" sizes="180x180" href="/assets/img/favicon/apple-touch-icon.png"/>

{# Fonts #}
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&family=Inter:wght@300;400;500;600;700&display=swap"/>

{# Styles #}
<link rel="stylesheet" href="/assets/css/editorial.css"/>
{% if extraCss %}{% for href in extraCss %}<link rel="stylesheet" href="{{ href }}"/>{% endfor %}{% endif %}
{% if layout == 'dispatch' or page.url and '/record/' in page.url and page.url != '/record/' %}<link rel="stylesheet" href="/assets/css/dispatch.css"/>{% endif %}

{# ── Analytics Suite — GA4 + GTM + Google Ads — installed 2026-05-13 ── #}

{# GA4 Global Site Tag (gtag.js) — G-05PYDYP5S0 #}
{% if site.ga4Id %}
<script async src="https://www.googletagmanager.com/gtag/js?id={{ site.ga4Id }}"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', '{{ site.ga4Id }}', { anonymize_ip: true });
  {% if site.gadsId %}gtag('config', '{{ site.gadsId }}');{% endif %}
</script>
{% endif %}

{# Google Tag Manager — GT-5TG37D4M #}
{% if site.gtmId %}
<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({"gtm.start":new Date().getTime(),event:"gtm.js"});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!="dataLayer"?"&l="+l:"";j.async=true;j.src="https://www.googletagmanager.com/gtm.js?id="+i+dl;f.parentNode.insertBefore(j,f);})(window,document,"script","dataLayer","{{ site.gtmId }}");</script>
{% endif %}

{# Google Tag Manager 2 — GT-TW5MMTD8 #}
{% if site.gtm2Id %}
<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({"gtm.start":new Date().getTime(),event:"gtm.js"});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!="dataLayer"?"&l="+l:"";j.async=true;j.src="https://www.googletagmanager.com/gtm.js?id="+i+dl;f.parentNode.insertBefore(j,f);})(window,document,"script","dataLayer","{{ site.gtm2Id }}");</script>
{% endif %}

{# ── TASK 8: Organization Schema (homepage only) ── #}
{% if page.url == "/" or isHome %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "NGO",
  "name": "{{ site.fullName }}",
  "alternateName": "{{ site.name }}",
  "url": "{{ site.url }}",
  "logo": "{{ site.url }}/assets/img/og/editorial.png",
  "foundingDate": "2024-06-02",
  "description": "{{ site.tagline }}",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "820 NW 64th Street",
    "addressLocality": "Miami",
    "addressRegion": "FL",
    "postalCode": "33150",
    "addressCountry": "US"
  },
  "telephone": "+18332417356",
  "email": "{{ site.contact.primary }}",
  "taxID": "{{ site.ein }}",
  "nonprofitStatus": "Nonprofit501c3",
  "founder": {
    "@type": "Person",
    "name": "Israel Lee Armstead"
  },
  "sameAs": [
    "https://twitter.com/wearegodweare",
    "https://www.tiktok.com/@e5blackdragons"
  ]
}
</script>
{% endif %}

{# ── TASK 8: BreadcrumbList Schema (interior pages) ── #}
{% if page.url != "/" and not isHome %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "{{ site.url }}/"},
    {"@type": "ListItem", "position": 2, "name": "{{ title or site.name }}", "item": "{{ site.url }}{{ page.url }}"}
  ]
}
</script>
{% endif %}
