<header class="vc-masthead">
  <div class="vc-masthead-rule" aria-hidden="true"><span class="mk">✦</span></div>
  <div class="vc-masthead-eyebrow">{{ site.established.city }} · Established <span aria-hidden="true">MMXXIV</span><span class="sr-only">2024</span></div>

  <div class="vc-foundation">
    <h1 class="vc-wordmark" aria-label="{{ site.name }}">
      <span class="em5" aria-hidden="true">E5</span>
      <span class="word">Enclave</span>
    </h1>

    {# KINETIC TAGLINE — cycles through Five Pillars + soul statement #}
    <p class="vc-tagline vc-tagline--kinetic" aria-live="polite">
      A <span class="ll">lineage-led think tank</span> building
      <span class="vc-kinetic-word" aria-label="FarmBlock · McCartney Academy · Block to Boardroom · Restitution 246 · the architecture of remedy">
        <span class="vc-kw-slot">FarmBlock</span>
      </span>
    </p>

    {# LIVE DISPATCH TICKER #}
    <div class="vc-dispatch-ticker" aria-label="Live board activity" role="complementary">
      <span class="vc-ticker-label">Board</span>
      <div class="vc-ticker-track" id="vc-ticker-track">
        <span class="vc-ticker-item">Loading dispatch&hellip;</span>
      </div>
    </div>

    <div class="vc-dates" role="list">
      <div class="vc-date" role="listitem">
        <span class="lbl">{{ site.established.label }}</span>
        <span class="val"><em>{{ site.established.date }}</em></span>
      </div>
      <div class="vc-date" role="listitem">
        <span class="lbl">{{ site.publicAnnouncement.label }}</span>
        <span class="val">{{ site.publicAnnouncement.date | safe }}</span>
      </div>
      <div class="vc-date" role="listitem">
        <span class="lbl">{{ site.edenLaunch.label }}</span>
        <span class="val">{{ site.edenLaunch.date | safe }}</span>
      </div>
    </div>

    <p class="vc-foundation-colophon">{{ site.colophon | safe }}</p>
  </div>
</header>

<script>
(function(){
  // ── KINETIC WORD-SWAP ──────────────────────────────────────────
  var words = [
    'FarmBlock',
    'McCartney Academy',
    'Block to Boardroom',
    'Restitution 246',
    'the architecture of remedy'
  ];
  var slot = document.querySelector('.vc-kw-slot');
  if (!slot) return;
  var idx = 0;
  function nextWord() {
    slot.style.opacity = '0';
    slot.style.transform = 'translateY(6px)';
    setTimeout(function() {
      idx = (idx + 1) % words.length;
      slot.textContent = words[idx];
      slot.style.opacity = '1';
      slot.style.transform = 'translateY(0)';
    }, 280);
  }
  slot.style.transition = 'opacity 0.28s ease, transform 0.28s ease';
  slot.style.display = 'inline-block';
  slot.style.opacity = '1';
  slot.style.transform = 'translateY(0)';
  setInterval(nextWord, 2600);

  // ── LIVE DISPATCH TICKER ───────────────────────────────────────
  var track = document.getElementById('vc-ticker-track');
  if (!track) return;

  // Fallback dispatches shown while API loads — PreSuasion-optimized (sue-cialdini-2026-0525)
  var fallback = [
    { text: '50 cities. 8 pillars. The Black Distress Index is free, public, and yours', age: 'dataset' },
    { text: 'A child who learns cooperative economics in middle school is a cooperative owner by 2035', age: 'doctrine' },
    { text: 'Liberty City median household wealth: $1,900. County median: $38,400. This is the gap we close', age: 'data' },
    { text: 'EDEN launches February 17, 2027. The coalition is forming now', age: 'live' },
    { text: 'Every FarmBlock member owns equity — not just wages', age: 'program' }
  ];

  function renderTicker(items) {
    track.innerHTML = '';
    items.forEach(function(item, i) {
      var span = document.createElement('span');
      span.className = 'vc-ticker-item';
      span.textContent = item.text + ' \u00b7 ' + item.age;
      if (i > 0) span.setAttribute('aria-hidden', 'true');
      track.appendChild(span);
    });
    if (items.length > 1) startScroll();
  }

  function ageString(isoDate) {
    var now = Date.now();
    var then = new Date(isoDate).getTime();
    var diff = Math.floor((now - then) / 1000);
    if (diff < 120) return 'just now';
    if (diff < 3600) return Math.floor(diff/60) + 'm ago';
    if (diff < 86400) return Math.floor(diff/3600) + 'h ago';
    return Math.floor(diff/86400) + 'd ago';
  }

  function startScroll() {
    var items = track.querySelectorAll('.vc-ticker-item');
    if (items.length < 2) return;
    var cur = 0;
    setInterval(function() {
      items[cur].style.opacity = '0';
      cur = (cur + 1) % items.length;
      items[cur].style.opacity = '1';
    }, 4000);
    items.forEach(function(el, i) {
      el.style.position = 'absolute';
      el.style.transition = 'opacity 0.4s ease';
      el.style.opacity = i === 0 ? '1' : '0';
      el.style.whiteSpace = 'nowrap';
    });
    track.style.position = 'relative';
    track.style.height = '1.4em';
  }

  // Try to fetch live dispatches from the board API
  fetch('/api/dispatches.json')
    .then(function(r) { return r.ok ? r.json() : null; })
    .then(function(data) {
      if (data && data.items && data.items.length) {
        var items = data.items.map(function(d) {
          return { text: d.summary || d.event_type, age: ageString(d.timestamp) };
        });
        renderTicker(items);
      } else {
        renderTicker(fallback);
      }
    })
    .catch(function() { renderTicker(fallback); });
})();
</script>
