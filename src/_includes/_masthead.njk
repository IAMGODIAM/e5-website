<header class="vc-masthead">
  <div class="vc-masthead-corners">
    <span class="l">Established<br/><em>{{ site.established.city }}</em></span>
    <span class="r">Eden Launch<br/><em>{{ site.edenLaunch }}</em></span>
  </div>
  <a href="/" class="vc-crest" role="img" aria-label="{{ site.name }}">
    <svg viewBox="0 0 540 360" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <line x1="60" y1="56" x2="230" y2="56" stroke="#0a0908" stroke-width="0.8" opacity="0.4"/>
      <text x="270" y="65" text-anchor="middle" font-family="Cormorant Garamond, serif" font-size="22" font-style="italic" fill="#6d1f20">✦</text>
      <line x1="310" y1="56" x2="480" y2="56" stroke="#0a0908" stroke-width="0.8" opacity="0.4"/>
      <text x="270" y="96" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" letter-spacing="7" font-weight="600" fill="#0a0908">FOUNDED MMXXVI · LIBERTY CITY</text>
      <text x="270" y="270" text-anchor="middle" font-family="Cormorant Garamond, serif" font-weight="500" fill="#0a0908">
        <tspan font-size="220">E</tspan>
        <tspan font-size="170" font-style="italic" fill="#6d1f20" dx="-12" dy="-18">5</tspan>
      </text>
      <line x1="90" y1="306" x2="240" y2="306" stroke="#6d1f20" stroke-width="0.9"/>
      <circle cx="270" cy="306" r="2.5" fill="#6d1f20"/>
      <line x1="300" y1="306" x2="450" y2="306" stroke="#6d1f20" stroke-width="0.9"/>
      <text x="270" y="338" text-anchor="middle" font-family="Cormorant Garamond, serif" font-size="17" font-style="italic" fill="#6b6457" letter-spacing="0.5">— {{ site.tagline }} —</text>
    </svg>
  </a>
  <div class="vc-foundation">
    <h1 class="vc-foundation-mark">ENCLAVE</h1>
    <div class="vc-foundation-credo">A Lineage-based Think Tank<span class="dot">·</span>comprised of a Coalition of the Willing.</div>
    <div class="vc-foundation-meta">Founded {{ site.established.date }} · {{ site.established.city }}</div>
  </div>
</header>
