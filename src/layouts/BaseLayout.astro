---
// E5 Enclave — Base Layout
// Design Bible v2 applied throughout
import '../styles/global.css';
import '../styles/components.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'E5 Enclave Incorporated',
  description = 'Sovereign institutional infrastructure for the Five Dimensions. Not programs. Not charity. Infrastructure. The center holds.',
  image = '/og-default.png',
} = Astro.props;

const siteUrl = 'https://e5enclave.com';
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <!-- Global Analytics: GA4 + Google Ads (site-wide tracking) — DAG warroom-karmelo-conversion-fire-2026-0619 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-05PYDYP5S0"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-05PYDYP5S0', { anonymize_ip: true });
    gtag('config', 'AW-16672489240');
  </script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title ? `${title} · E5 Enclave` : 'E5 Enclave Incorporated'}</title>

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={siteUrl + image} />
  <meta property="og:url" content={siteUrl} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={siteUrl + image} />

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "NGO",
    "name": "E5 Enclave Incorporated",
    "alternateName": "IAMGODIAM",
    "ein": "99-3822441",
    "url": "https://e5enclave.com",
    "description": "Sovereign institutional infrastructure for the Five Dimensions.",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Miami",
      "addressRegion": "FL",
      "addressCountry": "US"
    }
  }
  </script>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Theme color -->
  <meta name="theme-color" content="#111118" />
</head>

<body>
  <!-- Skip navigation for accessibility -->
  <a href="#main-content" class="sr-only sr-only-focusable">Skip to main content</a>

  <!-- Header -->
  <header class="header">
    <div class="header__inner container">
      <a href="/" class="header__logo" aria-label="E5 Enclave home">
        <span class="header__logo-icon">E5</span>
        <span class="header__logo-text">Enclave</span>
      </a>
      <nav class="header__nav" aria-label="Primary">
        <a href="/mission/" class="header__link">Mission</a>
        <a href="/pillars/" class="header__link">Pillars</a>
        <a href="/record/" class="header__link">Record</a>
        <a href="/coalition/" class="header__link">Coalition</a>
        <a href="/donate/" class="btn btn--primary btn--sm">Donate</a>
      </nav>
      <button class="header__menu-toggle" aria-label="Open menu" aria-expanded="false" id="menuToggle">
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
      </button>
    </div>
    <!-- Mobile menu -->
    <nav class="header__mobile-nav" id="mobileMenu" aria-label="Mobile">
      <a href="/mission/" class="header__mobile-link">Mission</a>
      <a href="/pillars/" class="header__mobile-link">Pillars</a>
      <a href="/record/" class="header__mobile-link">Record</a>
      <a href="/coalition/" class="header__mobile-link">Coalition</a>
      <a href="/donate/" class="header__mobile-link header__mobile-link--cta">Donate</a>
    </nav>
  </header>

  <!-- Main content -->
  <main id="main-content">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer__grid">
        <div class="footer__brand">
          <span class="display display--sm text-gold">E5 Enclave</span>
          <p class="body body--sm">Sovereign institutional infrastructure.<br/>Founded 2024. Liberty City, Miami.</p>
        </div>
        <div class="footer__col">
          <h3 class="body body--xs">The Record</h3>
          <ul class="footer__list">
            <li><a href="/record/dispatches/">Dispatches</a></li>
            <li><a href="/record/research/">Research</a></li>
            <li><a href="/record/measure-the-wound/">Measure the Wound</a></li>
            <li><a href="/artifacts/">Artifacts</a></li>
          </ul>
        </div>
        <div class="footer__col">
          <h3 class="body body--xs">About</h3>
          <ul class="footer__list">
            <li><a href="/mission/">Mission</a></li>
            <li><a href="/governance/">Governance</a></li>
            <li><a href="/faq/">FAQ</a></li>
            <li><a href="/contact/">Contact</a></li>
          </ul>
        </div>
        <div class="footer__col">
          <h3 class="body body--xs">Legal</h3>
          <ul class="footer__list">
            <li><a href="/privacy-policy/">Privacy</a></li>
            <li><a href="/terms-of-service/">Terms</a></li>
            <li><a href="/disclosures/">Disclosures</a></li>
            <li><a href="/accessibility/">Accessibility</a></li>
          </ul>
        </div>
      </div>
    </div>
    <div class="footer__bottom">
      <div class="container footer__bottom-inner">
        <span class="body body--xs text-muted">&copy; MMXXVI E5 Enclave Incorporated. All rights reserved.</span>
        <div class="footer__trust">
          <span class="body body--xs text-muted">EIN 99-3822441</span>
          <span class="body body--xs text-muted">·</span>
          <a href="https://sam.gov/entity/H8NGXEYE2HH8" class="body body--xs text-muted" target="_blank" rel="noopener">UEI H8NGXEYE2HH8</a>
          <span class="body body--xs text-muted">·</span>
          <span class="body body--xs text-muted">CAGE 07E88</span>
          <span class="body body--xs text-muted">·</span>
          <a href="https://apps.irs.gov/app/eos/details/#" class="body body--xs text-muted" target="_blank" rel="noopener">501(c)(3) verified</a>
        </div>
      </div>
    </div>
  </footer>

  <style>
    /* Header */
    .header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: var(--z-sticky);
      background: rgba(17, 17, 24, 0.9);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--color-border);
      height: var(--header-height);
    }

    .header__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 100%;
    }

    .header__logo {
      display: flex;
      align-items: baseline;
      gap: var(--s-3);
      text-decoration: none;
    }

    .header__logo-icon {
      font-family: var(--font-display);
      font-size: var(--text-2xl);
      font-weight: var(--weight-display);
      color: var(--color-primary);
    }

    .header__logo-text {
      font-family: var(--font-display);
      font-size: var(--text-lg);
      font-weight: var(--weight-display);
      color: var(--color-on-surface);
      letter-spacing: var(--ls-wide);
    }

    .header__nav {
      display: flex;
      align-items: center;
      gap: var(--s-6);
    }

    .header__link {
      font-size: var(--text-sm);
      font-weight: var(--weight-medium);
      color: var(--color-on-surface-secondary);
      text-decoration: none;
      transition: color var(--transition-fast);
      letter-spacing: var(--ls-wide);
      text-transform: uppercase;
    }

    .header__link:hover,
    .header__link[aria-current="page"] {
      color: var(--color-on-surface);
    }

    .header__nav .btn--sm {
      height: 36px;
      padding: 0 1rem;
      font-size: var(--text-xs);
    }

    .header__menu-toggle {
      display: none;
      flex-direction: column;
      justify-content: center;
      gap: 6px;
      width: 44px;
      height: 44px;
      padding: 10px;
      background: transparent;
      border: 1px solid var(--color-border-gold);
      border-radius: 8px;
      cursor: pointer;
      transition: border-color var(--transition-fast), background var(--transition-fast);
    }

    .header__menu-toggle:hover,
    .header__menu-toggle:focus-visible {
      border-color: var(--c-gold-500);
      background: var(--c-gold-muted);
      outline: none;
    }

    .header__menu-toggle span {
      display: block;
      width: 100%;
      height: 2px;
      border-radius: 2px;
      background: var(--c-gold-500);
      transition: transform var(--transition-fast), opacity var(--transition-fast);
    }

    /* Animate to X when menu is open */
    .header__menu-toggle[aria-expanded="true"] span:nth-child(1) {
      transform: translateY(8px) rotate(45deg);
    }
    .header__menu-toggle[aria-expanded="true"] span:nth-child(2) {
      opacity: 0;
    }
    .header__menu-toggle[aria-expanded="true"] span:nth-child(3) {
      transform: translateY(-8px) rotate(-45deg);
    }

    .header__mobile-nav {
      display: none;
      position: fixed;
      top: var(--header-height);
      left: 0;
      right: 0;
      bottom: 0;
      background: var(--color-surface);
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: var(--s-6);
      z-index: var(--z-overlay);
    }

    .header__mobile-nav.active {
      display: flex;
    }

    .header__mobile-link {
      font-family: var(--font-display);
      font-size: var(--text-3xl);
      color: var(--color-on-surface);
      text-decoration: none;
    }

    .header__mobile-link--cta {
      color: var(--color-primary);
    }

    @media (max-width: 768px) {
      .header__nav .header__link,
      .header__nav .btn {
        display: none;
      }
      .header__menu-toggle {
        display: flex;
      }
    }

    /* Footer */
    .footer {
      background: var(--color-surface-elevated);
      border-top: 1px solid var(--color-border);
      padding-top: var(--s-12);
      margin-top: var(--s-16);
    }

    .footer__grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: var(--s-8);
      padding-bottom: var(--s-10);
      border-bottom: 1px solid var(--color-border);
    }

    .footer__col h3 {
      color: var(--color-on-surface);
      margin-bottom: var(--s-4);
    }

    .footer__list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: var(--s-3);
    }

    .footer__list a {
      color: var(--color-on-surface-secondary);
      font-size: var(--text-sm);
      text-decoration: none;
      transition: color var(--transition-fast);
    }

    .footer__list a:hover {
      color: var(--color-primary);
    }

    .footer__bottom {
      padding: var(--s-5) 0;
    }

    .footer__bottom-inner {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .footer__trust {
      display: flex;
      gap: var(--s-3);
      align-items: center;
    }

    @media (max-width: 768px) {
      .footer__grid {
        grid-template-columns: 1fr 1fr;
        gap: var(--s-6);
      }
      .footer__brand {
        grid-column: span 2;
      }
      .footer__bottom-inner {
        flex-direction: column;
        gap: var(--s-3);
        text-align: center;
      }
    }

    /* Utility */
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    .sr-only-focusable:focus {
      position: static;
      width: auto;
      height: auto;
      padding: var(--s-2) var(--s-4);
      margin: 0;
      overflow: visible;
      clip: auto;
      white-space: normal;
      background: var(--color-primary);
      color: var(--color-primary-contrast);
      z-index: var(--z-modal);
    }
  </style>

  <script>
    // Mobile menu toggle
    const menuToggle = document.getElementById('menuToggle');
    const mobileMenu = document.getElementById('mobileMenu');
    if (menuToggle && mobileMenu) {
      menuToggle.addEventListener('click', () => {
        const isOpen = mobileMenu.classList.toggle('active');
        menuToggle.setAttribute('aria-expanded', isOpen);
      });
      // Close menu on link click
      mobileMenu.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.remove('active');
          menuToggle.setAttribute('aria-expanded', 'false');
        });
      });
    }
  </script>
  <!-- Conversion fires on real CTA clicks (donate/contact) — DAG warroom-karmelo-conversion-fire-2026-0619 -->
  <script>
    (function(){
      function fire(send_to){ try{ if(typeof gtag==='function'){ gtag('event','conversion',{'send_to':send_to}); } }catch(e){} }
      document.addEventListener('click', function(e){
        var a = e.target.closest && e.target.closest('a, button');
        if(!a) return;
        var href = (a.getAttribute('href')||'').toLowerCase();
        var txt  = (a.textContent||'').toLowerCase();
        // Donate intent: any link to /donate or external donate/zeffy/stripe, or a donate-labeled button
        if(/\/donate\/?$/.test(href) || /zeffy|stripe|checkout|givebutter/.test(href) || (/donate|give/.test(txt) && a.classList.contains('btn--primary'))){
          fire('AW-16672489240/_T-KCLGGnawcEJj-h44-'); // E5 — Donate Page CTA Click (PURCHASE)
          fire('AW-16672489240/B11GCOnl97UcEJj-h44-'); // E5 — Donate primary (biddable)
        }
        // Restitution intent: link to /restitution-246 or restitution/reparations-labeled CTA
        else if(/\/restitution-246\/?$/.test(href) || (/restitution|reparation/.test(txt) && a.classList.contains('btn--primary'))){
          fire('AW-16672489240/RJkQCMaJtKwcEJj-h44-'); // E5 — Restitution 246 CTA (SIGNUP)
        }
        // Contact intent: mailto or email-protection link, or contact-labeled card
        else if(href.indexOf('mailto:')===0 || href.indexOf('/cdn-cgi/l/email-protection')===0){
          fire('AW-16672489240/FeLJCIGooawcEJj-h44-'); // E5 — Contact Form Submitted (CONTACT)
        }
      }, true);
    })();
  </script>
</body>
</html>
