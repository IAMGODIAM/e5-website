---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{%- for p in collections.all -%}
{%- if p.url and p.url != '/404.html' and p.data.eleventyExcludeFromCollections != true %}
  <url>
    <loc>{{ site.url }}{{ p.url }}</loc>
    <lastmod>{{ p.date | isoDate }}</lastmod>
    <changefreq>{% if p.url == '/' %}weekly{% else %}monthly{% endif %}</changefreq>
    <priority>{% if p.url == '/' %}1.0{% elif '/blog/' in p.url or '/record/' in p.url %}0.8{% else %}0.7{% endif %}</priority>
  </url>
{%- endif -%}
{%- endfor %}
</urlset>
