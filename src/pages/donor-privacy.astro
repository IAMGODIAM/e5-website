---
import BaseLayout from '../layouts/BaseLayout.astro';

// Donor Privacy page — USA-focused, Cialdini: Authority + Transparency
// No external platform dependencies, fully self-contained
---

<BaseLayout
  title="Donor Privacy Policy"
  description="E5 Enclave donor privacy policy. Your donation. Your privacy. Your choice."
>

  <section class="section">
    <div class="container container--narrow">
      <span class="section-header__label">Donor Privacy</span>
      <h1 class="display display--md">Donor Privacy Policy</h1>
      <p class="body body--sm text-muted">Last updated: May 2026</p>

      <div class="legal-content">
        <h2>Our Commitment to Donors</h2>
        <p>E5 Enclave Incorporated respects donor privacy. We don't sell data. We don't rent lists. We don't share your information with third parties — except as required by law.</p>

        <h2>What We Collect</h2>
        <p>When you donate, we collect: name, email address, payment information (processed by PCI-compliant Stripe), and donation amount. For tax receipts, we collect your mailing address. Optionally: your permission to publish your name in our annual report.</p>

        <h2>How We Use Your Information</h2>
        <p>Your information is used solely to: process donations, send tax receipts, send newsletters (only if you opt in), and comply with IRS reporting requirements.</p>

        <h2>Public Disclosure</h2>
        <p>E5 is required to report certain donor information to the IRS on Form 990. Large donors may have their names publicly listed. You may request at any time that your name not appear in public reports. Contact accounts@e5enclave.com.</p>

        <h2>Your Rights</h2>
        <p>You may: (1) request a copy of your donor record, (2) request correction of inaccurate information, (3) request deletion of your personal data (except where retention is required by law), (4) opt out of all communications at any time.</p>

        <h2>Payment Security</h2>
        <p>Payment data is processed by Stripe (PCI-DSS Level 1 compliant). E5 never stores credit card numbers on our servers.</p>

        <h2>Contact</h2>
        <p>Questions about donor privacy: accounts@e5enclave.com. We respond within 5 business days.</p>
      </div>
    </div>
  </section>

  <style>
    .legal-content { margin-top: var(--s-8); }
    .legal-content h2 {
      font-family: var(--font-display);
      font-size: var(--text-xl);
      margin-top: var(--s-8);
      margin-bottom: var(--s-3);
    }
    .legal-content p {
      color: var(--color-on-surface-secondary);
      margin-bottom: var(--s-4);
      line-height: var(--lh-relaxed);
    }
  </style>
</BaseLayout>
