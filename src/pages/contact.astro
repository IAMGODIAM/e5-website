---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Contact E5 Enclave Incorporated. Apply to the Coalition, schedule a call, or send a message.">

  <section class="section">
    <div class="container container--narrow">
      <span class="section-header__label">Contact</span>
      <h1 class="display display--md">The door<br/><span class="text-gold">is open.</span></h1>
      <p class="body body--lg text-muted">Black-led organizations, individual builders, funders, and partner institutions: the Coalition is open.</p>
    </div>
  </section>

  <section class="section section--compact">
    <div class="container">
      <div class="contact-grid">
        <a href="/coalition/apply/" class="contact-card card card--gold-left">
          <h3>Apply to the Coalition</h3>
          <p>Institutions, builders, and aligned members. The doctrine must resonate. The door is open to those who come through on their own legs.</p>
          <span class="btn btn--tertiary">Start Application &rarr;</span>
        </a>
        <a href="mailto:accounts@e5enclave.com" class="contact-card card">
          <h3>Email the Council</h3>
          <p>General inquiries, partnership proposals, and coalition questions. A member of the Council will respond.</p>
          <span class="btn btn--tertiary">accounts@e5enclave.com</span>
        </a>
        <a href="/donate/" class="contact-card card">
          <h3>Give to the Work</h3>
          <p>Tax-deductible donations. $25/month sustains one family on FarmBlock. Every dollar has a specific impact.</p>
          <span class="btn btn--tertiary">Donate &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--compact">
    <div class="container container--narrow">
      <h2 class="heading heading--sm">Send a message</h2>
      <p class="body text-muted" style="margin-bottom:24px;">Prefer to write directly? Send us a note and a member of the Council will respond.</p>
      <form id="contactForm" style="display:flex;flex-direction:column;gap:14px;max-width:540px;">
        <input type="text" id="cf-name" name="name" class="form__input" placeholder="Your name" required />
        <input type="email" id="cf-email" name="email" class="form__input" placeholder="your@email.com" required />
        <input type="text" id="cf-org" name="organization" class="form__input" placeholder="Organization (optional)" />
        <textarea id="cf-message" name="message" class="form__input" rows="5" placeholder="How can the Council help?" required></textarea>
        <button type="submit" class="btn btn--primary cta-primary" id="cf-submit">Send message &rarr;</button>
        <p id="cf-status" style="display:none;" class="body text-gold"></p>
      </form>
    </div>
  </section>

  <section class="section section--compact">
    <div class="container container--narrow">
      <h2 class="heading heading--sm">Organization Details</h2>
      <div class="org-details">
        <div class="org-detail">
          <span class="org-detail__label">Legal Name</span>
          <span class="org-detail__value">E5 Enclave Incorporated</span>
        </div>
        <div class="org-detail">
          <span class="org-detail__label">EIN</span>
          <span class="org-detail__value">99-3822441</span>
        </div>
        <div class="org-detail">
          <span class="org-detail__label">UEI</span>
          <span class="org-detail__value">H8NGXEYE2HH8</span>
        </div>
        <div class="org-detail">
          <span class="org-detail__label">Founded</span>
          <span class="org-detail__value">June 2024</span>
        </div>
        <div class="org-detail">
          <span class="org-detail__label">Location</span>
          <span class="org-detail__value">Liberty City, Miami, FL</span>
        </div>
        <div class="org-detail">
          <span class="org-detail__label">Status</span>
          <span class="org-detail__value">501(c)(3) Tax-Exempt</span>
        </div>
      </div>
    </div>
  </section>

  <style>
    .contact-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--s-5);
    }

    .contact-card {
      display: flex;
      flex-direction: column;
      gap: var(--s-3);
      padding: var(--s-6);
      text-decoration: none;
      color: inherit;
    }

    .contact-card h3 {
      font-family: var(--font-display);
      font-size: var(--text-xl);
    }

    .contact-card p {
      color: var(--color-on-surface-secondary);
      font-size: var(--text-sm);
    }

    .org-details {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--s-4);
      padding: var(--s-6);
      background: var(--color-surface-elevated);
      border-radius: var(--radius-lg);
      margin-top: var(--s-5);
    }

    .org-detail {
      display: flex;
      flex-direction: column;
      gap: var(--s-1);
    }

    .org-detail__label {
      font-size: var(--text-xs);
      text-transform: uppercase;
      letter-spacing: var(--ls-wider);
      color: var(--color-on-surface-muted);
    }

    .org-detail__value {
      font-family: var(--font-display);
      font-size: var(--text-lg);
    }

    @media (max-width: 768px) {
      .contact-grid { grid-template-columns: 1fr; }
      .org-details { grid-template-columns: 1fr; }
    }
  </style>

  <script>
    document.getElementById('contactForm')?.addEventListener('submit', function(e){
      e.preventDefault();
      var btn=document.getElementById('cf-submit'); var status=document.getElementById('cf-status');
      var payload={
        name:(document.getElementById('cf-name')||{}).value||'',
        email:(document.getElementById('cf-email')||{}).value||'',
        organization:(document.getElementById('cf-org')||{}).value||'',
        message:(document.getElementById('cf-message')||{}).value||'',
        subject:'website-contact',
        site_variant:(window.__E5_VARIANT||document.documentElement.getAttribute('data-variant')||'alpha'),
        source:'contact'
      };
      if(!payload.email){ return; }
      btn.disabled=true; btn.textContent='Sending…';
      fetch('https://sue-45c3e283.base44.app/functions/contactForm',{
        method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)
      }).then(function(r){return r.json();}).then(function(d){
        status.style.display='block';
        status.textContent = d && d.success ? 'Message received. The Council will respond.' : 'Thank you — your message was sent.';
        document.getElementById('contactForm').reset(); btn.textContent='Sent ✓';
        try{ if(typeof gtag==='function'){ gtag('event','conversion',{'send_to':'AW-16672489240/FeLJCIGooawcEJj-h44-'}); gtag('event','generate_lead',{'event_label':'contact_form'}); } }catch(e){}
      }).catch(function(){
        status.style.display='block'; status.textContent='Sent. Thank you.'; btn.textContent='Sent ✓';
      });
    });
  </script>
</BaseLayout>
