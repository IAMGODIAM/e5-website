---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="The Record" description="Dispatches, research, and data from the E5 Enclave think tank.">

  <section class="section section--compact">
    <div class="container container--narrow">
      <span class="section-header__label">The Record</span>
      <h1 class="display display--lg">Dispatches from<br/><span class="text-gold">the Coalition.</span></h1>
      <p class="body body--lg text-muted">Research, program updates, and coalition intelligence. Published openly. Audited against practice.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-header__label">Founding Documents</span>
        <h2 class="heading heading--lg">Three documents anchor the founding work.</h2>
      </div>

      <div class="doc-grid">
        <a href="/record/parallel-negros/" class="doc-card card card--gold-left">
          <span class="doc-card__type">Think Tank Dispatch</span>
          <h3 class="doc-card__title">Parallel Negros</h3>
          <p class="doc-card__desc">A foundational comparative dispatch examining the parallel architectures that shape the lineage's path through American history.</p>
          <span class="doc-card__cta">Read on E5 &rarr;</span>
        </a>
        <a href="/record/measure-the-wound/" class="doc-card card card--gold-left">
          <span class="doc-card__type">Foundational Record</span>
          <h3 class="doc-card__title">Measure the Wound</h3>
          <p class="doc-card__desc">Documentation of the harms we repair. The evidentiary foundation against which every E5 program is built.</p>
          <span class="doc-card__cta">Read on E5 &rarr;</span>
        </a>
        <a href="/record/restitution-246/" class="doc-card card card--gold-left">
          <span class="doc-card__type">Research Framework</span>
          <h3 class="doc-card__title">Restitution 246</h3>
          <p class="doc-card__desc">A disciplined wage-loss and opportunity-loss research framework anchored to the Craemer (2015) methodology.</p>
          <span class="doc-card__cta">Read the Research &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <style>
    .doc-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--s-5);
    }

    .doc-card {
      display: flex;
      flex-direction: column;
      gap: var(--s-3);
      padding: var(--s-6);
      text-decoration: none;
      color: inherit;
    }

    .doc-card__type {
      font-size: var(--text-xs);
      text-transform: uppercase;
      letter-spacing: var(--ls-wider);
      color: var(--color-primary);
    }

    .doc-card__title {
      font-family: var(--font-display);
      font-size: var(--text-xl);
    }

    .doc-card__desc {
      color: var(--color-on-surface-secondary);
      font-size: var(--text-sm);
    }

    .doc-card__cta {
      color: var(--color-primary);
      font-size: var(--text-sm);
      font-weight: var(--weight-medium);
    }

    @media (max-width: 768px) {
      .doc-grid { grid-template-columns: 1fr; }
    }
  </style>
</BaseLayout>
