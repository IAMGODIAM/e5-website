---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Support the Work"
  description="Your gift funds evidence systems, farms, schools, and policy tools. Tax-deductible. EIN 99-3822441."
>

  <section class="section section--compact">
    <div class="container container--narrow">
      <span class="section-header__label">Support the Work</span>
      <h1 class="display display--lg">Your gift funds the evidence systems,<br/>the farms, the schools, and the policy tools.</h1>
    </div>
  </section>

  <!-- Donation Tiers -->
  <section class="section donate">
    <div class="container">
      <div class="section-header">
        <span class="section-header__label">Give Monthly</span>
        <h2 class="section-header__title">Every dollar. <span class="text-gold">Specific impact.</span></h2>
        <p class="section-header__subtitle">Recurring gifts are the backbone of sustainable infrastructure. Monthly giving sustains programs year-round.</p>
      </div>

      <div class="donate__tiers">
        <!-- $10 tier -->
        <div class="donate__tier">
          <span class="tier__amount">$10<span class="tier__freq">/month</span></span>
          <h3 class="tier__impact">One family's water filter</h3>
          <p class="tier__desc">Maintained for a year through FarmBlock water access initiatives.</p>
          <input type="radio" name="amount" id="amt10" class="tier__radio" />
          <label for="amt10" class="btn btn--secondary tier__btn">Select</label>
        </div>

        <!-- $25 tier (DEFAULT) -->
        <div class="donate__tier donate__tier--featured">
          <span class="tier__badge">Most Popular</span>
          <span class="tier__amount">$25<span class="tier__freq">/month</span></span>
          <h3 class="tier__impact">One family on FarmBlock waitlist</h3>
          <p class="tier__desc">Documented, verified, and placed on the FarmBlock registry.</p>
          <input type="radio" name="amount" id="amt25" class="tier__radio" checked />
          <label for="amt25" class="btn btn--primary tier__btn">Selected</label>
        </div>

        <!-- $50 tier -->
        <div class="donate__tier">
          <span class="tier__amount">$50<span class="tier__freq">/month</span></span>
          <h3 class="tier__impact">One acre of community land</h3>
          <p class="tier__desc">Mapped, registered, and documented for cooperative ownership.</p>
          <input type="radio" name="amount" id="amt50" class="tier__radio" />
          <label for="amt50" class="btn btn--secondary tier__btn">Select</label>
        </div>

        <!-- $100 tier -->
        <div class="donate__tier">
          <span class="tier__amount">$100<span class="tier__freq">/month</span></span>
          <h3 class="tier__impact">One water well GPS-verified</h3>
          <p class="tier__desc">Complete documentation with photo proof and chain-of-custody record.</p>
          <input type="radio" name="amount" id="amt100" class="tier__radio" />
          <label for="amt100" class="btn btn--secondary tier__btn">Select</label>
        </div>
      </div>

      <!-- Custom amount -->
      <div class="donate__custom">
        <label for="customAmount" class="body body--sm text-muted">Custom amount:</label>
        <div class="donate__custom-input">
          <span class="donate__dollar">$</span>
          <input type="number" id="customAmount" class="donate__input" placeholder="Enter amount" min="1" />
          <span class="donate__freq">/month</span>
        </div>
      </div>

      <!-- Frequency toggle -->
      <div class="donate__freq-toggle">
        <span class="body body--text-sm">Frequency:</span>
        <label class="donate__freq-option">
          <input type="radio" name="freq" value="monthly" checked />
          <span>Monthly</span>
        </label>
        <label class="donate__freq-option">
          <input type="radio" name="freq" value="once" />
          <span>One-time</span>
        </label>
      </div>

      <!-- Continue button -->
      <div class="donate__action">
        <button type="button" class="btn btn--primary btn--lg">Continue to Payment</button>
        <p class="body body--xs text-muted donate__trust">
          <svg width="14" height="14" viewBox="0 0 20 20" style="vertical-align: middle; margin-right: 4px;"><path fill="currentColor" d="M10 2L3 6v5c0 4.5 3 8.5 7 9.5 4-1 7-5 7-9.5V6l-7-4zm-1 12l-3-3 1.5-1.5L9 11l4.5-4.5L15 8l-6 6z"/></svg>
          Secure payment via Stripe &middot; 256-bit SSL &middot; EIN 99-3822441
        </p>
      </div>
    </div>
  </section>

  <!-- Trust Section -->
  <section class="section section--elevated trust-section">
    <div class="container">
      <div class="section-header">
        <span class="section-header__label">Radical Transparency</span>
        <h2 class="section-header__title">Your gift is <span class="text-gold">tax-deductible.</span><br/>Your impact is <span class="text-gold">verifiable.</span></h2>
      </div>

      <div class="trust-grid">
        <div class="trust-item">
          <span class="trust-item__icon">&#x2713;</span>
          <h3>501(c)(3) Verified</h3>
          <p>EIN 99-3822441. IRS-recognized tax-exempt since 2024.</p>
          <a href="https://apps.irs.gov/app/eos/details/#" class="btn btn--tertiary" target="_blank" rel="noopener">Verify on IRS &rarr;</a>
        </div>
        <div class="trust-item">
          <span class="trust-item__icon">&#x2713;</span>
          <h3>SAM.gov Registered</h3>
          <p>UEI H8NGXEYE2HH8. CAGE 07E88. Federal registrant in good standing.</p>
          <a href="https://sam.gov/entity/H8NGXEYE2HH8" class="btn btn--tertiary" target="_blank" rel="noopener">Verify on SAM.gov &rarr;</a>
        </div>
        <div class="trust-item">
          <span class="trust-item__icon">&#x2713;</span>
          <h3>Open Financials</h3>
          <p>Form 990, audited financials, and governing bylaws published openly.</p>
          <a href="/governance/" class="btn btn--tertiary">View Financials &rarr;</a>
        </div>
        <div class="trust-item">
          <span class="trust-item__icon">&#x2713;</span>
          <h3>Directed Giving</h3>
          <p>Every dollar directed to specific programs. No admin overhead on donations.</p>
          <a href="/governance/" class="btn btn--tertiary">How Funds Work &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .donate__tiers {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: var(--s-4);
    }

    .donate__tier {
      position: relative;
      padding: var(--s-6);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      text-align: center;
      transition: all var(--transition-base);
    }

    .donate__tier:hover {
      border-color: var(--color-border-hover);
    }

    .donate__tier--featured {
      border-color: var(--color-primary);
      box-shadow: var(--shadow-gold);
      transform: scale(1.02);
    }

    .tier__badge {
      position: absolute;
      top: -10px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--color-primary);
      color: var(--color-primary-contrast);
      font-size: var(--text-xs);
      padding: 2px 12px;
      border-radius: var(--radius-full);
      text-transform: uppercase;
      letter-spacing: var(--ls-wider);
    }

    .tier__amount {
      font-family: var(--font-display);
      font-size: var(--text-4xl);
      font-weight: var(--weight-display);
      display: block;
    }

    .tier__freq {
      font-size: var(--text-lg);
      color: var(--color-on-surface-muted);
    }

    .tier__impact {
      font-family: var(--font-display);
      font-size: var(--text-lg);
      margin: var(--s-4) 0 var(--s-2);
    }

    .tier__desc {
      color: var(--color-on-surface-secondary);
      font-size: var(--text-sm);
      margin-bottom: var(--s-4);
    }

    .tier__radio {
      position: absolute;
      opacity: 0;
    }

    .tier__btn {
      width: 100%;
      margin-top: var(--s-3);
    }

    .donate__custom {
      max-width: 400px;
      margin: var(--s-8) auto 0;
      text-align: center;
    }

    .donate__custom-input {
      display: flex;
      align-items: center;
      gap: var(--s-2);
      margin-top: var(--s-3);
    }

    .donate__dollar {
      font-family: var(--font-display);
      font-size: var(--text-2xl);
      color: var(--color-primary);
    }

    .donate__input {
      flex: 1;
      height: 48px;
      padding: 0 var(--s-4);
      background: var(--color-surface-elevated);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-sm);
      color: var(--color-on-surface);
      font-size: var(--text-base);
    }

    .donate__freq {
      color: var(--color-on-surface-muted);
    }

    .donate__freq-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: var(--s-5);
      margin-top: var(--s-6);
    }

    .donate__freq-option {
      display: flex;
      align-items: center;
      gap: var(--s-2);
      cursor: pointer;
      padding: var(--s-2) var(--s-4);
      border-radius: var(--radius-full);
      border: 1px solid var(--color-border);
      transition: all var(--transition-fast);
    }

    .donate__freq-option:hover,
    .donate__freq-option:has(input:checked) {
      border-color: var(--color-primary);
    }

    .donate__action {
      text-align: center;
      margin-top: var(--s-8);
    }

    .donate__trust {
      margin-top: var(--s-4);
    }

    .trust-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--s-6);
    }

    .trust-item__icon {
      color: var(--color-primary);
      font-size: var(--text-2xl);
    }

    .trust-item h3 {
      font-family: var(--font-display);
      font-size: var(--text-lg);
      margin: var(--s-3) 0 var(--s-2);
    }

    .trust-item p {
      color: var(--color-on-surface-secondary);
      font-size: var(--text-sm);
      margin-bottom: var(--s-3);
    }

    @media (max-width: 768px) {
      .donate__tiers { grid-template-columns: 1fr; }
      .trust-grid { grid-template-columns: 1fr; }
    }
  </style>
</BaseLayout>
