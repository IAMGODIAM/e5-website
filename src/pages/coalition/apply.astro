---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Apply to the Coalition"
  description="Apply to join the E5 Enclave Coalition of the Willing. Institutions, builders, and aligned members."
>

  <section class="section">
    <div class="container container--narrow">
      <span class="section-header__label">The Coalition</span>
      <h1 class="display display--lg">Apply to<br/><span class="text-gold">the Coalition.</span></h1>
      <p class="body body--lg text-muted">
        Black-led organizations, individual builders, funders, and partner institutions.
        The doctrine must resonate. The door is open to those who come through on their own legs.
      </p>
    </div>
  </section>

  <!-- Application Steps -->
  <section class="section section--compact apply-form">
    <div class="container container--narrow">
      <!-- Step indicator -->
      <div class="steps">
        <div class="steps__item steps__item--active">
          <span class="steps__num">1</span>
          <span class="steps__label">Your Info</span>
        </div>
        <div class="steps__item">
          <span class="steps__num">2</span>
          <span class="steps__label">Your Lane</span>
        </div>
        <div class="steps__item">
          <span class="steps__num">3</span>
          <span class="steps__label">The Covenant</span>
        </div>
        <div class="steps__item">
          <span class="steps__num">4</span>
          <span class="steps__label">Submit</span>
        </div>
      </div>

      <!-- Step 1: Contact Info -->
      <div class="apply-step apply-step--active" id="step1">
        <h2 class="heading heading--md">Tell us about yourself.</h2>
        <form class="form">
          <div class="form__group">
            <label for="name" class="form__label">Full Name <span class="form__required">*</span></label>
            <input type="text" id="name" class="form__input" required placeholder="Your full name" />
          </div>
          <div class="form__group">
            <label for="email" class="form__label">Email <span class="form__required">*</span></label>
            <input type="email" id="email" class="form__input" required placeholder="your@email.com" />
          </div>
          <div class="form__group">
            <label for="org" class="form__label">Organization (if applicable)</label>
            <input type="text" id="org" class="form__input" placeholder="Organization name" />
          </div>
          <div class="form__group">
            <label for="reason" class="form__label">Why are you drawn to E5?</label>
            <textarea id="reason" class="form__input form__textarea" placeholder="Briefly describe your motivation. What resonates? What do you want to build?" rows="4"></textarea>
          </div>
          <button type="button" class="btn btn--primary form__btn" onclick="nextStep(2)">Continue &rarr;</button>
        </form>
      </div>

      <!-- Step 2: Choose Your Lane -->
      <div class="apply-step" id="step2">
        <h2 class="heading heading--md">Which lane?</h2>
        <p class="body body--sm text-muted" style="margin-bottom: var(--s-5);">The Coalition grows the Coalition. Every member contributes in their own way.</p>
        <div class="lanes">
          <label class="lane-card">
            <input type="radio" name="lane" value="give" class="lane-card__radio" />
            <span class="lane-card__icon">&#x1F4B0;</span>
            <h3>I want to give.</h3>
            <p>Financial stake of any size. Your gift funds the work.</p>
          </label>
          <label class="lane-card">
            <input type="radio" name="lane" value="showup" class="lane-card__radio" />
            <span class="lane-card__icon">&#x1F44D;</span>
            <h3>I want to show up.</h3>
            <p>Skills, time, presence. Eight hours minimum.</p>
          </label>
          <label class="lane-card">
            <input type="radio" name="lane" value="institution" class="lane-card__radio" />
            <span class="lane-card__icon">&#x1F3DB;</span>
            <h3>I represent an institution.</h3>
            <p>Black-led organization seeking Coalition membership.</p>
          </label>
          <label class="lane-card">
            <input type="radio" name="lane" value="build" class="lane-card__radio" />
            <span class="lane-card__icon">&#x1F528;</span>
            <h3>I want to build with you.</h3>
            <p>Co-builder, aligned partner. The doctrine resonates.</p>
          </label>
        </div>
        <div class="form__nav">
          <button type="button" class="btn btn--secondary" onclick="nextStep(1)">&larr; Back</button>
          <button type="button" class="btn btn--primary" onclick="nextStep(3)">Continue &rarr;</button>
        </div>
      </div>

      <!-- Step 3: The Covenant -->
      <div class="apply-step" id="step3">
        <h2 class="heading heading--md">The Covenant.</h2>
        <p class="body body--sm text-muted" style="margin-bottom: var(--s-5);">To be of the Coalition is to commit:</p>
        <div class="pledges">
          <label class="pledge">
            <input type="checkbox" class="pledge__check" />
            <span class="pledge__num">i.</span>
            <span class="pledge__text">A financial stake of any size.</span>
          </label>
          <label class="pledge">
            <input type="checkbox" class="pledge__check" />
            <span class="pledge__num">ii.</span>
            <span class="pledge__text">Four convenings per year, minimum.</span>
          </label>
          <label class="pledge">
            <input type="checkbox" class="pledge__check" />
            <span class="pledge__num">iii.</span>
            <span class="pledge__text">Eight hours of presence at the work.</span>
          </label>
          <label class="pledge">
            <input type="checkbox" class="pledge__check" />
            <span class="pledge__num">iv.</span>
            <span class="pledge__text">Introduce two others to what we are building.</span>
          </label>
        </div>
        <div class="form__nav">
          <button type="button" class="btn btn--secondary" onclick="nextStep(2)">&larr; Back</button>
          <button type="button" class="btn btn--primary" onclick="nextStep(4)">Continue &rarr;</button>
        </div>
      </div>

      <!-- Step 4: Submit -->
      <div class="apply-step" id="step4">
        <h2 class="heading heading--md">Submit your application.</h2>
        <p class="body text-muted" style="margin-bottom: var(--s-5);">Review your information. A member of the Council will respond within 48 hours.</p>

        <div class="review">
          <div class="review__item">
            <span class="review__label">Name:</span>
            <span class="review__value" id="reviewName">—</span>
          </div>
          <div class="review__item">
            <span class="review__label">Email:</span>
            <span class="review__value" id="reviewEmail">—</span>
          </div>
          <div class="review__item">
            <span class="review__label">Lane:</span>
            <span class="review__value" id="reviewLane">—</span>
          </div>
        </div>

        <div class="form__nav">
          <button type="button" class="btn btn--secondary" onclick="nextStep(3)">&larr; Back</button>
          <button type="submit" class="btn btn--primary btn--lg form__submit">Submit Application</button>
        </div>
      </div>

      <!-- Confirmation -->
      <div class="apply-confirm" id="confirm">
        <h2 class="heading heading--lg text-gold">Application received.</h2>
        <p class="body">A member of the Council will respond within 48 hours.</p>
        <p class="body body--sm text-muted">While you wait: <a href="/record/">Read the Founding Doctrine &rarr;</a></p>
      </div>
    </div>
  </section>

  <style>
    .steps {
      display: flex;
      justify-content: center;
      gap: var(--s-6);
      margin-bottom: var(--s-10);
    }

    .steps__item {
      display: flex;
      align-items: center;
      gap: var(--s-2);
      opacity: 0.3;
      transition: opacity var(--transition-fast);
    }

    .steps__item--active {
      opacity: 1;
    }

    .steps__num {
      width: 28px;
      height: 28px;
      border-radius: var(--radius-full);
      border: 1px solid var(--color-border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: var(--text-sm);
      font-weight: var(--weight-medium);
    }

    .steps__item--active .steps__num {
      background: var(--color-primary);
      color: var(--color-primary-contrast);
      border-color: var(--color-primary);
    }

    .steps__label {
      font-size: var(--text-sm);
      color: var(--color-on-surface-secondary);
    }

    .apply-step { display: none; }
    .apply-step--active { display: block; }

    .form__group {
      margin-bottom: var(--s-5);
    }

    .form__label {
      display: block;
      font-size: var(--text-sm);
      font-weight: var(--weight-medium);
      margin-bottom: var(--s-2);
    }

    .form__required {
      color: var(--color-error);
    }

    .form__input {
      width: 100%;
      height: 48px;
      padding: 0 var(--s-4);
      background: var(--color-surface-elevated);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-sm);
      color: var(--color-on-surface);
      font-family: var(--font-body);
      font-size: var(--text-base);
    }

    .form__input:focus {
      outline: none;
      border-color: var(--color-primary);
      box-shadow: 0 0 0 3px var(--c-gold-muted);
    }

    .form__input::placeholder {
      color: var(--color-on-surface-muted);
    }

    .form__textarea {
      height: auto;
      padding: var(--s-4);
      resize: vertical;
      min-height: 100px;
    }

    .form__btn {
      margin-top: var(--s-3);
    }

    .form__nav {
      display: flex;
      gap: var(--s-4);
      margin-top: var(--s-6);
    }

    .form__submit {
      background: var(--color-primary);
      color: var(--color-primary-contrast);
    }

    /* Lane cards */
    .lanes {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--s-4);
    }

    .lane-card {
      padding: var(--s-5);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      cursor: pointer;
      transition: all var(--transition-fast);
      display: flex;
      flex-direction: column;
      gap: var(--s-2);
    }

    .lane-card:hover {
      border-color: var(--color-border-hover);
    }

    .lane-card:has(input:checked) {
      border-color: var(--color-primary);
      background: var(--c-gold-muted);
    }

    .lane-card__radio {
      position: absolute;
      opacity: 0;
    }

    .lane-card__icon {
      font-size: var(--text-2xl);
    }

    .lane-card h3 {
      font-family: var(--font-display);
      font-size: var(--text-lg);
    }

    .lane-card p {
      color: var(--color-on-surface-secondary);
      font-size: var(--text-sm);
    }

    /* Pledges */
    .pledges {
      display: flex;
      flex-direction: column;
      gap: var(--s-3);
    }

    .pledge {
      display: flex;
      align-items: center;
      gap: var(--s-3);
      padding: var(--s-4);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      cursor: pointer;
      transition: all var(--transition-fast);
    }

    .pledge:hover {
      border-color: var(--color-border-hover);
    }

    .pledge:has(input:checked) {
      border-color: var(--color-primary);
    }

    .pledge__check {
      width: 20px;
      height: 20px;
      accent-color: var(--color-primary);
    }

    .pledge__num {
      font-family: var(--font-display);
      color: var(--color-primary);
      min-width: 24px;
    }

    .pledge__text {
      font-size: var(--text-sm);
    }

    /* Review */
    .review {
      padding: var(--s-6);
      background: var(--color-surface-elevated);
      border-radius: var(--radius-lg);
    }

    .review__item {
      display: flex;
      justify-content: space-between;
      padding: var(--s-3) 0;
      border-bottom: 1px solid var(--color-border);
    }

    .review__item:last-child { border-bottom: none; }

    .review__label {
      font-size: var(--text-sm);
      color: var(--color-on-surface-muted);
      text-transform: uppercase;
      letter-spacing: var(--ls-wider);
    }

    .review__value {
      font-size: var(--text-sm);
    }

    .apply-confirm {
      text-align: center;
      padding: var(--s-10) 0;
      display: none;
    }

    .apply-confirm.active { display: block; }

    @media (max-width: 768px) {
      .steps { gap: var(--s-3); }
      .steps__label { display: none; }
      .lanes { grid-template-columns: 1fr; }
    }
  </style>

  <script>
    function nextStep(n) {
      document.querySelectorAll('.apply-step').forEach(s => {
        s.classList.remove('apply-step--active');
      });
      document.querySelectorAll('.steps__item').forEach((s, i) => {
        s.classList.toggle('steps__item--active', i < n);
      });
      const stepEl = document.getElementById('step' + n);
      if (stepEl) stepEl.classList.add('apply-step--active');

      if (n === 4) {
        document.getElementById('reviewName').textContent =
          document.getElementById('name').value || '—';
        document.getElementById('reviewEmail').textContent =
          document.getElementById('email').value || '—';
        const lane = document.querySelector('input[name="lane"]:checked');
        document.getElementById('reviewLane').textContent =
          lane ? lane.parentElement.querySelector('h3').textContent : '—';
      }
    }

    // Handle form submission
    document.querySelector('.apply-form form')?.addEventListener('submit', function(e) {
      e.preventDefault();
      /* E5FP wire — capture the applicant to the backend (DAG warroom-e5-forms-npm-wiring-2026-0619) */
      var lanePick = document.querySelector('input[name="lane"]:checked');
      var pledgeBoxes = document.querySelectorAll('.pledge__check');
      var allPledged = pledgeBoxes.length>0 && Array.prototype.every.call(pledgeBoxes, function(c){return c.checked;});
      var payload = {
        name:  (document.getElementById('name')||{}).value || '',
        email: (document.getElementById('email')||{}).value || '',
        org:   (document.getElementById('org')||{}).value || '',
        reason:(document.getElementById('reason')||{}).value || '',
        lane:  lanePick ? lanePick.value : '',
        pledged: allPledged,
        site_variant: (window.__E5_VARIANT || document.documentElement.getAttribute('data-variant') || 'alpha'),
        source: 'coalition-apply'
      };
      fetch('https://sue-45c3e283.base44.app/functions/coalitionApply', {
        method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(payload)
      }).catch(function(err){ console.error('coalition submit', err); });
      /* show confirmation regardless (non-blocking UX) */
      document.querySelectorAll('.apply-step').forEach(s => s.classList.remove('apply-step--active'));
      document.getElementById('confirm').classList.add('active');
      document.querySelector('.steps').style.display = 'none';
      /* FIRE Coalition SIGNUP conversion — DAG warroom-karmelo-conversion-fire-2026-0619 */
      try{ if(typeof gtag==='function'){ gtag('event','conversion',{'send_to':'AW-16672489240/H8n8CNfl97UcEJj-h44-'}); gtag('event','generate_lead',{'event_label':'coalition_application'}); } }catch(e){}
    });
  </script>
</BaseLayout>
