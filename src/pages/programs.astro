---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Programs" description="E5 Enclave programs: McCartney Academy, FarmBlock, Black Dragons Initiative, and more.">

  <section class="section section--compact">
    <div class="container container--narrow">
      <span class="section-header__label">Programs</span>
      <h1 class="display display--lg">The proof<br/><span class="text-gold">is in the programs.</span></h1>
      <p class="body body--lg text-muted">Three flagship programs. Each one evidence. Each one infrastructure. Each one a proof point for the doctrine.</p>
    </div>
  </section>

  <section class="section programs">
    <div class="container">
      <div class="programs__grid">
        <!-- Flagship 1 -->
        <div class="program-card card card--gold-left">
          <div class="program-card__header">
            <span class="program-card__num">01</span>
            <span class="program-card__tag">Flagship</span>
          </div>
          <h3 class="program-card__title">McCartney Academy</h3>
          <p class="program-card__desc">Black-centered K–12 private school. Lineage-centered curriculum. STEM, leadership, emerging technologies. Built in Liberty City. Designed to produce the next generation of institutional architects.</p>
          <div class="program-card__status">
            <span class="program-card__status-dot"></span>
            Phase I — Founding Cohort
          </div>
        </div>

        <!-- Flagship 2 -->
        <div class="program-card card card--gold-left">
          <div class="program-card__header">
            <span class="program-card__num">02</span>
            <span class="program-card__tag">Flagship</span>
          </div>
          <h3 class="program-card__title">FarmBlock</h3>
          <p class="program-card__desc">Cooperative urban agriculture. Anti-food-apartheid infrastructure. 50+ cities surveyed for Phase II feasibility. Land stewardship, food sovereignty, and circular economics in practice.</p>
          <div class="program-card__status">
            <span class="program-card__status-dot"></span>
            Phase II — Scaling
          </div>
        </div>

        <!-- Flagship 3 -->
        <div class="program-card card card--gold-left">
          <div class="program-card__header">
            <span class="program-card__num">03</span>
            <span class="program-card__tag">Flagship</span>
          </div>
          <h3 class="program-card__title">Block to the Boardroom</h3>
          <p class="program-card__desc">Civic leadership pipeline. Training community members in governance, public policy, and institutional management. From neighborhood blocks to boardroom tables.</p>
          <div class="program-card__status">
            <span class="program-card__status-dot"></span>
            Active — Cohort Forming
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Other Programs -->
  <section class="section section--compact section--elevated">
    <div class="container">
      <h2 class="heading heading--md" style="text-align: center; margin-bottom: var(--s-8);">Other Programs</h2>
      <div class="other-programs">
        <div class="other-prog card">
          <h3>Restitution 246</h3>
          <p>Research framework. Craemer (2015) methodology. Open record, auditable, built to be cited.</p>
        </div>
        <div class="other-prog card">
          <h3>Innovation Lab</h3>
          <p>Emerging technologies, AI systems, and sovereign tools for community use.</p>
        </div>
        <div class="other-prog card">
          <h3>First Offering</h3>
          <p>The store. The covenant made tangible. Products from the work, for the work.</p>
        </div>
        <div class="other-prog card">
          <h3>Black Dragons Initiative</h3>
          <p>Security, resilience, and sovereign capability for Black-led institutions.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section cta-section section--compact">
    <div class="container container--narrow" style="text-align: center;">
      <h2 class="heading heading--lg">Want to fund a program?<br/><em class="text-gold">Give to the work.</em></h2>
      <div style="margin-top: var(--s-6);">
        <a href="/donate/" class="btn btn--primary">Donate Now</a>
      </div>
    </div>
  </section>

  <style>
    .programs__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--s-5);
    }

    .program-card {
      padding: var(--s-6);
      display: flex;
      flex-direction: column;
      gap: var(--s-3);
    }

    .program-card__header {
      display: flex;
      align-items: center;
      gap: var(--s-3);
    }

    .program-card__num {
      font-family: var(--font-display);
      font-size: var(--text-3xl);
      color: var(--color-primary);
      font-weight: var(--weight-display);
    }

    .program-card__tag {
      font-size: var(--text-xs);
      text-transform: uppercase;
      letter-spacing: var(--ls-wider);
      color: var(--color-primary);
      padding: 2px 10px;
      background: var(--c-gold-muted);
      border-radius: var(--radius-full);
    }

    .program-card__title {
      font-family: var(--font-display);
      font-size: var(--text-2xl);
    }

    .program-card__desc {
      color: var(--color-on-surface-secondary);
      line-height: var(--lh-normal);
    }

    .program-card__status {
      display: flex;
      align-items: center;
      gap: var(--s-2);
      font-size: var(--text-sm);
      color: var(--color-on-surface-muted);
      margin-top: auto;
      padding-top: var(--s-4);
      border-top: 1px solid var(--color-border);
    }

    .program-card__status-dot {
      width: 8px;
      height: 8px;
      border-radius: var(--radius-full);
      background: var(--color-primary);
    }

    .other-programs {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--s-4);
    }

    .other-prog {
      padding: var(--s-5);
    }

    .other-prog h3 {
      font-family: var(--font-display);
      font-size: var(--text-lg);
      margin-bottom: var(--s-2);
    }

    .other-prog p {
      color: var(--color-on-surface-secondary);
      font-size: var(--text-sm);
    }

    .cta-section em { font-style: italic; }

    @media (max-width: 768px) {
      .programs__grid { grid-template-columns: 1fr; }
      .other-programs { grid-template-columns: 1fr; }
    }
  </style>
</BaseLayout>
