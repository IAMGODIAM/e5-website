---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqs = [
  {
    q: "What is E5 Enclave?",
    a: "E5 Enclave Incorporated is a 501(c)(3) think tank and convening organization. We build sovereign institutional infrastructure for the Five Dimensions: Environmental, Economic, Educational, Engagement, and Emancipated. Founded June 2024 in Liberty City, Miami."
  },
  {
    q: "Is my donation tax-deductible?",
    a: "Yes. E5 Enclave Incorporated is a 501(c)(3) tax-exempt organization. EIN 99-3822441. All donations are tax-deductible to the extent allowed by law. You will receive a tax receipt for your records."
  },
  {
    q: "What is the Coalition?",
    a: "The Coalition of the Willing is E5's network of individuals, institutions, and partner organizations. To be of the Coalition is to commit: (i) a financial stake of any size, (ii) four convenings per year, (iii) eight hours of presence at the work, and (iv) introduce two others to what we are building."
  },
  {
    q: "What is Restitution 246?",
    a: "Restitution 246 is E5's disciplined research framework for calculating wage-loss and opportunity-loss for American chattel slavery. We apply the Craemer (2015) wage-hour methodology. This is one research lane of the reparations question — not the whole road. The framework is open and auditable."
  },
  {
    q: "Is E5 a political organization?",
    a: "No. E5 is a 501(c)(3) think tank. We publish research and build institutions. Per IRS regulations, we do not endorse political candidates, contribute to campaigns, or engage in political campaign intervention. Our research speaks for itself."
  },
  {
    q: "How do I apply to the Coalition?",
    a: "Visit our Coalition Application page. The process has four steps: (1) your information, (2) your lane (give, show up, represent an institution, or build), (3) the covenant pledge, and (4) submit. A Council member responds within 48 hours."
  },
  {
    q: "What programs does E5 run?",
    a: "Three flagship programs: McCartney Academy (Black-centered K–12), FarmBlock (cooperative urban agriculture), and Block to the Boardroom (civic leadership pipeline). Additional programs include the Restitution 246 research framework, Innovation Lab, and First Offering store."
  },
  {
    q: "How is E5 different from other nonprofits?",
    a: "E5 is built to be a sovereign institution — not a program, not a charity, not a grant-chaser. We build infrastructure that outlasts funding cycles. We operate agentic-first (AI agents under human direction). We publish all research openly. We are Black-first: built by and for the lineage."
  },
  {
    q: "Can I volunteer?",
    a: "Yes. The Coalition welcomes volunteers with skills in legal, technical, research, or community work. Eight hours of presence is the covenant. Apply via our Coalition Application page."
  },
  {
    q: "Where is E5 located?",
    a: "E5 Enclave Incorporated is founded and based in Liberty City, Miami, Florida. Our work extends from Liberty City to the nation."
  }
];
---

<BaseLayout title="FAQ" description="Frequently asked questions about E5 Enclave Incorporated, the Coalition, donations, and programs.">

  <section class="section">
    <div class="container container--narrow">
      <span class="section-header__label">FAQ</span>
      <h1 class="display display--md">Frequently<br/><span class="text-gold">asked questions.</span></h1>
    </div>
  </section>

  <section class="section section--compact">
    <div class="container container--narrow">
      <div class="faq-list">
        {faqs.map((faq, i) => (
          <details class="faq-item" open={i < 3}>
            <summary class="faq-item__q">
              <span class="faq-item__num">{(i + 1).toString().padStart(2, '0')}</span>
              <span>{faq.q}</span>
            </summary>
            <div class="faq-item__a">
              <p class="body text-muted">{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--compact">
    <div class="container container--narrow" style="text-align: center;">
      <p class="body text-muted">Still have questions?</p>
      <a href="/contact/" class="btn btn--primary" style="margin-top: var(--s-3);">Contact the Council</a>
    </div>
  </section>

  <style>
    .faq-list {
      display: flex;
      flex-direction: column;
      gap: var(--s-2);
    }

    .faq-item {
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      overflow: hidden;
      transition: border-color var(--transition-fast);
    }

    .faq-item:hover {
      border-color: var(--color-border-hover);
    }

    .faq-item summary {
      list-style: none;
      cursor: pointer;
    }

    .faq-item summary::-webkit-details-marker {
      display: none;
    }

    .faq-item__q {
      display: flex;
      align-items: center;
      gap: var(--s-4);
      padding: var(--s-5);
      font-family: var(--font-display);
      font-size: var(--text-lg);
      user-select: none;
    }

    .faq-item__q::after {
      content: '+';
      margin-left: auto;
      font-size: var(--text-xl);
      color: var(--color-primary);
    }

    .faq-item[open] .faq-item__q::after {
      content: '—';
    }

    .faq-item__num {
      font-family: var(--font-mono);
      font-size: var(--text-sm);
      color: var(--color-primary);
    }

    .faq-item__a {
      padding: 0 var(--s-5) var(--s-5) calc(var(--s-4) + 2ch + var(--s-5));
    }

    .faq-item__a p {
      color: var(--color-on-surface-secondary);
      line-height: var(--lh-relaxed);
    }
  </style>
</BaseLayout>
