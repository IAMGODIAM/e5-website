{
  "name": "e5-enclave-website",
  "version": "2.0.0",
  "description": "E5 Enclave Incorporated — Sovereign Institutional Website",
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0 --port 3000",
    "build": "npm run build:cinematic && astro build",
    "preview": "astro preview --host 0.0.0.0 --port 3000",
    "build:cinematic": "node scripts/build-cinematic.mjs",
    "qa:cinematic": "playwright test -c playwright.cinematic.config.mjs",
    "qa:chassis": "node scripts/chassis-sweep.mjs",
    "render:cinematic": "docker build -f tools/hyperframes/Dockerfile -t e5-hyperframes . && docker run --rm -v $PWD/artifacts:/work/artifacts e5-hyperframes",
    "preview:cinematic": "cd tools/hyperframes && npm install && npm run preview",
    "optimize:assets": "node scripts/optimize-assets.mjs",
    "qa:adapters": "node scripts/verify-frame-adapters.mjs"
  },
  "dependencies": {
    "astro": "7.1.3",
    "gsap": "3.15.0",
    "three": "0.185.1"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "esbuild": "0.28.1",
    "pixelmatch": "7.2.0",
    "pngjs": "7.0.0"
  }
}
